<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="StartTooler.Components.ShimmerPlaceholder">

    <UserControl.Styles>
        <!-- Shimmer 单格脉动（Opacity 0.4↔1.0 循环） -->
        <Style Selector="Border.shimmer-cell">
            <Setter Property="Opacity" Value="0.4"/>
            <Style.Animations>
                <Animation Duration="0:0:1.2"
                           IterationCount="INFINITE"
                           PlaybackDirection="Alternate">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0.4"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1.0"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </UserControl.Styles>

    <WrapPanel x:Name="RootPanel"/>
</UserControl>
