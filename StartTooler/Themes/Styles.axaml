<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 全局基础样式 -->
    <Style Selector="Window">
        <Setter Property="Background" Value="{DynamicResource Bg.Outer}"/>
        <Setter Property="FontFamily" Value="{DynamicResource Font.Primary}"/>
    </Style>

    <!--
        全局 Button ControlTemplate (替换 FluentTheme 默认模板)

        FluentTheme 默认 Button 模板含 4 个状态层 Border (Rest/PointerOver/Pressed/Disabled)，
        每个状态层用半透明遮罩叠加在 Background 上。当 Background=Transparent 时，
        PointerOver 状态层无可着底色，hover 视觉反馈几乎不可见。

        这个自定义模板简化为：Border 直接渲染 Background/BorderBrush/CornerRadius，
        ContentPresenter 渲染内容。hover/active/disabled 完全靠属性 setter 控制，
        不依赖 PseudoClasses 状态层切换。
    -->
    <Style Selector="Button">
        <Setter Property="Template">
            <ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      Foreground="{TemplateBinding Foreground}"
                                      FontSize="{TemplateBinding FontSize}"
                                      FontWeight="{TemplateBinding FontWeight}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- 标题栏设置按钮 -->
    <Style Selector="Button.header-button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.header-button:pointerover">
        <Setter Property="Background" Value="{DynamicResource Bg.HoverSubtle}"/>
    </Style>

    <!-- 时间轴节点 -->
    <Style Selector="Button.timeline-node">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.timeline-node /template/ ContentPresenter">
        <Setter Property="Padding" Value="0"/>
    </Style>
    <!-- v0.11 spec/15 §3.4：timeline-node hover/selected 状态 -->
    <Style Selector="Button.timeline-node:pointerover">
        <Setter Property="Background" Value="{DynamicResource Bg.HoverSubtle}"/>
    </Style>
    <!-- 选中态用 Accent.Stellar 当左侧 2px 强调条（spec §3.4）。Element 摆不到 Button 模板外，
         通过 Background tint + 圆角体现；强调条由 Border.BorderThickness/Brush 局部表现。 -->
    <Style Selector="Border.timeline-selected-bar">
        <Setter Property="Width" Value="3"/>
        <Setter Property="Background" Value="{DynamicResource Accent.Stellar}"/>
        <Setter Property="CornerRadius" Value="2"/>
    </Style>

    <!-- v0.11 spec/15 §2.2：快捷时间胶囊（今天 / 本周 / 本月 / 今年）。单选语义 + 主题色 Accent.Stellar。 -->
    <Style Selector="ToggleButton.quick-filter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Accent.Stellar}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{DynamicResource Accent.Stellar}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Pill}"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="ToggleButton.quick-filter:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource Text.Primary}"/>
        <Setter Property="Background" Value="{DynamicResource Bg.HoverSubtle}"/>
    </Style>
    <!-- 选中态：主题色（Accent.Stellar）实色底 + 反白文字（spec §2.2 截图）。 -->
    <Style Selector="ToggleButton.quick-filter:checked,
                    ToggleButton.quick-filter.selected">
        <Setter Property="Background" Value="{DynamicResource Accent.Stellar}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Accent.Stellar}"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.Inverse}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- v0.11 spec/15 §2.3：年份/月份/日计数胶囊（选中 = 反白） -->
    <Style Selector="Border.count-pill">
        <Setter Property="Background" Value="{DynamicResource Bg.SurfaceElevated}"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Pill}"/>
    </Style>
    <Style Selector="Border.count-pill.selected">
        <Setter Property="Background" Value="{DynamicResource Timeline.Selected}"/>
    </Style>

    <!-- v0.6.1: 标签分类节点（左栏「标签」tab 列表项，视觉沿用 timeline-node） -->
    <Style Selector="Button.tag-node">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.tag-node /template/ ContentPresenter">
        <Setter Property="Padding" Value="0"/>
    </Style>
    <Style Selector="Button.tag-node:pointerover">
        <Setter Property="Background" Value="{DynamicResource Bg.HoverSubtle}"/>
    </Style>

    <!-- v0.6.1: 左栏 TabControl（[时间 | 标签]） -->
    <Style Selector="TabControl.group-tabs">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="12,8,12,4"/>
    </Style>
    <Style Selector="TabControl.group-tabs > TabItem">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- 照片缩略图 -->
    <Style Selector="Button.photo-tile">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.photo-tile /template/ ContentPresenter">
        <Setter Property="Padding" Value="0"/>
    </Style>
    <Style Selector="Button.photo-tile:pointerover /template/ Border">
        <Setter Property="BoxShadow" Value="0 4 12 0 rgba(0,0,0,0.4)"/>
    </Style>

    <!-- 主按钮 -->
    <Style Selector="Button.primary-button">
        <Setter Property="Background" Value="{DynamicResource Gradient.PrimaryButton}"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.Inverse}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="600"/>
        <Setter Property="Padding" Value="28,9"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.primary-button:disabled">
        <Setter Property="Opacity" Value="0.55"/>
    </Style>

    <!-- 次按钮 -->
    <Style Selector="Button.secondary-button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Bg.Divider}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.Primary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.secondary-button:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource Accent.Stellar}"/>
    </Style>
    <Style Selector="Button.secondary-button:disabled">
        <Setter Property="Opacity" Value="0.55"/>
    </Style>

    <!-- Select 按钮 -->
    <Style Selector="Button.select-button">
        <Setter Property="Background" Value="{DynamicResource Bg.Surface}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Bg.Divider}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.select-button:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource Accent.Stellar}"/>
    </Style>

    <!-- Tab 项 -->
    <Style Selector="Button.tab-item">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="16,4"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.tab-item:pointerover">
        <Setter Property="Background" Value="{DynamicResource Bg.HoverSubtle}"/>
    </Style>
    <Style Selector="Button.tab-item.active">
        <Setter Property="Background" Value="{DynamicResource Bg.SurfaceElevated}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Accent.Stellar}"/>
        <Setter Property="Foreground" Value="{DynamicResource Accent.Stellar}"/>
    </Style>
    <Style Selector="Button.tab-item:disabled">
        <Setter Property="Foreground" Value="{DynamicResource Accent.Stellar}"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>

    <!-- ComboBox 样式 -->
    <Style Selector="ComboBox">
        <Setter Property="Background" Value="{DynamicResource Bg.Surface}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Bg.Divider}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.Primary}"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>
    <Style Selector="ComboBox:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource Accent.Stellar}"/>
    </Style>

    <!-- v0.6: 工具栏排序 ComboBox（紧凑型，比默认小一号贴工具栏） -->
    <Style Selector="ComboBox.sort-combo">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>

    <!-- TextBox 样式（深色主题） -->
    <Style Selector="TextBox">
        <Setter Property="Background" Value="{DynamicResource Bg.Surface}"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.Primary}"/>
        <Setter Property="CaretBrush" Value="{DynamicResource Accent.Stellar}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Bg.Divider}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="12,8"/>
    </Style>
    <Style Selector="TextBox:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource Accent.Stellar}"/>
    </Style>
    <Style Selector="TextBox:focus">
        <Setter Property="BorderBrush" Value="{DynamicResource Accent.Stellar}"/>
    </Style>
    <Style Selector="TextBox:disabled">
        <Setter Property="Opacity" Value="0.5"/>
    </Style>
    <Style Selector="TextBox /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource Bg.Surface}"/>
    </Style>

    <!-- v0.11: 表单验证错误样式（spec §3.2）—— 边框转 State.Danger 提醒用户 -->
    <Style Selector="TextBox.error /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource State.Danger}"/>
        <Setter Property="BorderThickness" Value="1.5"/>
    </Style>

    <!-- NumericUpDown 样式（深色主题） -->
    <Style Selector="NumericUpDown">
        <Setter Property="Background" Value="{DynamicResource Bg.Surface}"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.Primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Bg.Divider}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>
    <Style Selector="NumericUpDown:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource Accent.Stellar}"/>
    </Style>

    <!-- Expander 样式（深色主题：header + 容器都用主题色） -->
    <Style Selector="Expander">
        <Setter Property="Background" Value="{DynamicResource Bg.Surface}"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.Primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Bg.Divider}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}"/>
    </Style>
    <Style Selector="Expander ToggleButton#PART_toggle /template/ Border">
        <Setter Property="Background" Value="{DynamicResource Bg.Surface}"/>
    </Style>
    <Style Selector="Expander ToggleButton#PART_toggle:pointerover /template/ Border">
        <Setter Property="Background" Value="{DynamicResource Bg.Hover}"/>
    </Style>

    <!-- ScrollViewer 样式 -->
    <Style Selector="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- TextBlock 默认样式 -->
    <Style Selector="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Font.Primary}"/>
    </Style>

    <!-- 刷新按钮样式 -->
    <Style Selector="Button.refresh-button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.refresh-button:pointerover">
        <Setter Property="Background" Value="{DynamicResource Bg.HoverSubtle}"/>
    </Style>
    <Style Selector="Button.refresh-button:pointerover Path.refresh-icon">
        <Setter Property="Fill" Value="{DynamicResource Accent.Stellar}"/>
    </Style>
    <Style Selector="Button.refresh-button:disabled">
        <Setter Property="Opacity" Value="0.4"/>
    </Style>

    <!-- 刷新按钮旋转动画（Scanning 状态） -->
    <Style Selector="Button.refresh-button.Scanning Path.refresh-icon">
        <Setter Property="RenderTransform">
            <Setter.Value>
                <RotateTransform Angle="0"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- v2.3: 工具栏按钮 -->
    <Style Selector="Button.toolbar-button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="12,5"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.toolbar-button:pointerover">
        <Setter Property="Background" Value="{DynamicResource Bg.HoverSubtle}"/>
    </Style>
    <Style Selector="Button.toolbar-button:disabled">
        <Setter Property="Opacity" Value="0.4"/>
    </Style>

    <!-- v2.3: 工具栏危险按钮 (删除) -->
    <Style Selector="Button.toolbar-button-danger">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource State.Danger}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="12,5"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.toolbar-button-danger:pointerover">
        <Setter Property="Background" Value="{DynamicResource Bg.HoverSubtle}"/>
    </Style>
    <Style Selector="Button.toolbar-button-danger:disabled">
        <Setter Property="Opacity" Value="0.4"/>
    </Style>

    <!-- v0.8: 垃圾筒卡片底部小按钮（缩略图上的「恢复/下载/清理」） -->
    <Style Selector="Button.trash-action">
        <Setter Property="Background" Value="#33FFFFFF"/>
        <Setter Property="Foreground" Value="#E6FFFFFF"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Height" Value="22"/>
        <Setter Property="MinWidth" Value="36"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.trash-action:pointerover">
        <Setter Property="Background" Value="#66FFFFFF"/>
    </Style>
    <Style Selector="Button.trash-action:disabled">
        <Setter Property="Opacity" Value="0.4"/>
    </Style>

    <!-- v0.8: 垃圾筒卡片底部危险按钮（清理 = 彻底删除） -->
    <Style Selector="Button.trash-action-danger">
        <Setter Property="Background" Value="#33FFFFFF"/>
        <Setter Property="Foreground" Value="#FFCC6666"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Height" Value="22"/>
        <Setter Property="MinWidth" Value="36"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.trash-action-danger:pointerover">
        <Setter Property="Background" Value="#66FF6666"/>
    </Style>
    <Style Selector="Button.trash-action-danger:disabled">
        <Setter Property="Opacity" Value="0.4"/>
    </Style>

    <!-- v0.11: 垃圾筒卡片底部恢复按钮（绿色调，区别于白色/红色，spec §8.1） -->
    <Style Selector="Button.trash-action-restore">
        <Setter Property="Background" Value="#33A5D6A7"/>
        <Setter Property="Foreground" Value="#A5D6A7"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Height" Value="22"/>
        <Setter Property="MinWidth" Value="36"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="BorderBrush" Value="#66BB6A40"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="Button.trash-action-restore:pointerover">
        <Setter Property="Background" Value="#4CA5D6A7"/>
    </Style>
    <Style Selector="Button.trash-action-restore:disabled">
        <Setter Property="Opacity" Value="0.4"/>
    </Style>

    <!-- v0.11: Toast 横幅内的链接按钮（撤销/跳转，spec §6.2） -->
    <Style Selector="Button.link-button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#4DD0E1"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="8,2"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.link-button:pointerover">
        <Setter Property="Foreground" Value="#80DEEA"/>
    </Style>

    <!-- 导航 Rail 按钮样式 (C15 NavItem) -->
    <Style Selector="Button.nav-item">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}"/>
        <Setter Property="Padding" Value="8,12"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Height" Value="48"/>
        <Setter Property="Width" Value="80"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.nav-item:pointerover">
        <Setter Property="Background" Value="{DynamicResource Bg.HoverSubtle}"/>
        <!-- v0.11: hover 前景色变化（spec §3.3） -->
        <Setter Property="Foreground" Value="{DynamicResource Text.Primary}"/>
    </Style>
    <Style Selector="Button.nav-item:pressed">
        <Setter Property="Background" Value="{DynamicResource Bg.Divider}"/>
    </Style>
    <Style Selector="Button.nav-item.active">
        <Setter Property="Background" Value="{DynamicResource Bg.SurfaceElevated}"/>
        <Setter Property="Foreground" Value="{DynamicResource Accent.Stellar}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Accent.Stellar}"/>
        <Setter Property="BorderThickness" Value="2,0,0,0"/>
        <!-- v0.11: 激活态加粗（spec §3.3） -->
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- ============================================================
         v0.11: 骨架屏样式（spec doc/0.11/spec/05-ui-interaction-review.md §9）
         用 Border.skeleton 渲染占位条；.pulse 加 1.5s 呼吸动画
         ============================================================ -->
    <Style Selector="Border.skeleton">
        <Setter Property="Background" Value="{DynamicResource Bg.SurfaceElevated}"/>
    </Style>

    <Style Selector="Border.skeleton.pulse">
        <Style.Animations>
            <Animation Duration="0:0:1.5" IterationCount="INFINITE" Easing="SineEaseInOut">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0.3"/>
                </KeyFrame>
                <KeyFrame Cue="50%">
                    <Setter Property="Opacity" Value="0.6"/>
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0.3"/>
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- ============================================================
         v0.11: 设置页 TabControl 样式（spec §12.1）
         ============================================================ -->
    <Style Selector="TabControl.settings-tabs">
        <Setter Property="TabStripPlacement" Value="Top"/>
    </Style>
    <Style Selector="TabControl.settings-tabs WrapPanel">
        <!-- 隐藏 WrapPanel 子项在 TabStripPlacement=Top 时的额外空隙，避免整体偏上 -->
    </Style>
    <Style Selector="TabControl.settings-tabs TabItem">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}"/>
        <Setter Property="Padding" Value="16,10"/>
    </Style>
    <Style Selector="TabControl.settings-tabs TabItem:selected">
        <Setter Property="Foreground" Value="{DynamicResource Accent.Stellar}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

</Styles>
