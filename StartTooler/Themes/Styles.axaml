<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 全局基础样式 -->
    <Style Selector="Window">
        <Setter Property="Background" Value="{DynamicResource Bg.Outer}"/>
        <Setter Property="FontFamily" Value="{DynamicResource Font.Primary}"/>
    </Style>

    <!-- 标题栏设置按钮 -->
    <Style Selector="Button.header-button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.header-button:pointerover">
        <Setter Property="Background" Value="{DynamicResource Bg.Hover}"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.Primary}"/>
    </Style>

    <!-- 时间轴节点 -->
    <Style Selector="Button.timeline-node">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.timeline-node /template/ ContentPresenter">
        <Setter Property="Padding" Value="0"/>
    </Style>

    <!-- 照片缩略图 -->
    <Style Selector="Button.photo-tile">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.photo-tile /template/ ContentPresenter">
        <Setter Property="Padding" Value="0"/>
    </Style>
    <Style Selector="Button.photo-tile:pointerover /template/ Border">
        <Setter Property="BoxShadow" Value="0 4 12 0 rgba(0,0,0,0.4)"/>
    </Style>

    <!-- 主按钮 -->
    <Style Selector="Button.primary-button">
        <Setter Property="Background" Value="{DynamicResource Gradient.PrimaryButton}"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.Inverse}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="600"/>
        <Setter Property="Padding" Value="24,0"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.primary-button:pressed">
        <Setter Property="Opacity" Value="0.9"/>
    </Style>
    <Style Selector="Button.primary-button:disabled">
        <Setter Property="Opacity" Value="0.5"/>
    </Style>

    <!-- Tab 项 -->
    <Style Selector="Button.tab-item">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="4,0"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.tab-item:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource Text.Primary}"/>
    </Style>
    <Style Selector="Button.tab-item:disabled">
        <Setter Property="Foreground" Value="{DynamicResource Accent.Stellar}"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>

    <!-- ComboBox 样式 -->
    <Style Selector="ComboBox">
        <Setter Property="Background" Value="{DynamicResource Bg.Surface}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Bg.Divider}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.Primary}"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>
    <Style Selector="ComboBox:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource Accent.Stellar}"/>
    </Style>

    <!-- ScrollViewer 样式 -->
    <Style Selector="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- TextBlock 默认样式 -->
    <Style Selector="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Font.Primary}"/>
    </Style>

</Styles>
