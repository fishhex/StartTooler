<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 背景层 -->
    <Color x:Key="Bg.Outer">#0A0E1A</Color>
    <Color x:Key="Bg.Surface">#161B2E</Color>
    <Color x:Key="Bg.SurfaceElevated">#1F2438</Color>
    <Color x:Key="Bg.Divider">#2A3050</Color>
    <Color x:Key="Bg.Hover">#252B45</Color>
    <Color x:Key="Bg.HoverSubtle">#3A4060</Color>

    <!-- 边框层（v0.11 spec/06 §6 — 不再硬编码 BorderColor） -->
    <Color x:Key="Border.Subtle">#4A5273</Color>
    <Color x:Key="Border.Strong">#8892B0</Color>

    <!-- 文字层 -->
    <Color x:Key="Text.Primary">#E8EAF0</Color>
    <Color x:Key="Text.Secondary">#8892B0</Color>
    <Color x:Key="Text.Tertiary">#5A6280</Color>
    <Color x:Key="Text.Disabled">#4A5273</Color>
    <Color x:Key="Text.Inverse">#0A0E1A</Color>

    <!-- 强调色 -->
    <Color x:Key="Accent.Stellar">#4FC3F7</Color>
    <Color x:Key="Accent.Stellar.Subtle">#1F4A5F</Color>     <!-- 15% Accent.Stellar ↔ 85% Bg.Outer 混合观感 -->
    <Color x:Key="Accent.Nebula">#B388FF</Color>
    <Color x:Key="Accent.Aurora">#4DD0E1</Color>

    <!-- 状态色 -->
    <Color x:Key="State.Quiet">#4A5273</Color>
    <Color x:Key="State.Warning">#FFA726</Color>
    <Color x:Key="State.Danger">#FF5252</Color>
    <Color x:Key="State.Success">#4DD0E1</Color>

    <!-- 状态图标色（v0.11 spec/10 §3.2） -->
    <Color x:Key="StatusIcon.Synced">#4DD0E1</Color>
    <Color x:Key="StatusIcon.RemoteOnly">#FFA726</Color>
    <Color x:Key="StatusIcon.LocalOnly">#4A5273</Color>
    <Color x:Key="StatusIcon.Attention">#FF5252</Color>

    <!-- 时间轴专用色 -->
    <Color x:Key="Timeline.Selected">#FF6B6B</Color>
    <Color x:Key="Timeline.Dot.Selected">#4FC3F7</Color>
    <Color x:Key="Timeline.Line">#8892B0</Color>

    <!-- ============ v0.11: 统计仪表盘图表用色（spec/19 §5.2） ============ -->
    <Color x:Key="Chart.Heatmap.Zero">#1E2233</Color>
    <Color x:Key="Chart.Heatmap.Max">#4FC3F7</Color>
    <Color x:Key="Chart.Bar.Accent">#4FC3F7</Color>
    <Color x:Key="Chart.Bar.Secondary">#8892B0</Color>

    <!-- macOS 交通灯 -->
    <Color x:Key="TrafficLight.Red">#FF5F57</Color>
    <Color x:Key="TrafficLight.Yellow">#FFBD2E</Color>
    <Color x:Key="TrafficLight.Green">#28C940</Color>

    <!-- ============ v0.11: 叠加层颜色（spec §15.2 硬编码替换） ============ -->
    <Color x:Key="Overlay.Dark">#CC0A0E1A</Color>
    <Color x:Key="Overlay.Light">#CCFFFFFF</Color>
    <Color x:Key="Overlay.Selection">#334FC3F7</Color>
    <Color x:Key="Overlay.Scrim">#80000000</Color>
    <Color x:Key="Overlay.MarqueeFill">#204FC3F7</Color>
    <Color x:Key="Overlay.MarqueeStroke">#4FC3F7</Color>
    <Color x:Key="Overlay.Toast">#E60A0E1A</Color>

    <!-- ============ v0.11: 标签条专用色（spec §15.2） ============ -->
    <Color x:Key="Tag.QualityBg">#CC3A1F1A</Color>
    <Color x:Key="Tag.QualityFg">#FFCC8888</Color>
    <Color x:Key="Tag.ScoreBadgeText">#FFFFFF</Color>
    <Color x:Key="Tag.ScoreBadgeAltText">#E6FFFFFF</Color>
    <Color x:Key="Tag.ScoreBadgeFaint">#80FFFFFF</Color>
    <Color x:Key="Tag.ScoreBadgeQuiet">#99FFFFFF</Color>

    <!-- ============ v0.11: 云端/状态色（spec §15.2） ============ -->
    <Color x:Key="Cloud.Accent">#4DD0E1</Color>
    <Color x:Key="Cloud.MissingBg">#33A5D6A7</Color>
    <Color x:Key="Cloud.MissingFg">#A5D6A7</Color>
    <Color x:Key="Cloud.RestoreBorder">#66BB6A40</Color>
    <Color x:Key="Cloud.NotUploaded">#4A5273</Color>
    <Color x:Key="Cloud.WarnBg">#CCFFFFFF</Color>
    <Color x:Key="Cloud.WarnStroke">#FFA726</Color>
    <Color x:Key="Cloud.TrashBar">#4DD0E1</Color>

    <!-- ============ v0.11: 卡片用色（spec §15.2） ============ -->
    <Color x:Key="Card.FooterBg">#CC0A0E1A</Color>
    <Color x:Key="Card.FooterText">#E6FFFFFF</Color>
    <Color x:Key="Card.EmptyStateStroke">#4A5273</Color>

    <!-- ============ v0.11: Chip 用色（spec §15.2） ============ -->
    <Color x:Key="Chip.DeleteHover">#E63946</Color>
    <Color x:Key="Chip.DeleteHoverLight">#66FF6666</Color>
    <Color x:Key="Chip.DeleteHoverFg">#FFFFFF</Color>
    <Color x:Key="Chip.ActionBg">#33FFFFFF</Color>
    <Color x:Key="Chip.ActionBgHover">#66FFFFFF</Color>
    <Color x:Key="Chip.ActionDangerFg">#FFCC6666</Color>

    <!-- 批量标签编辑 diff 预览用色 -->
    <Color x:Key="Tag.DiffAddedBg">#CC1E5B3A</Color>
    <Color x:Key="Tag.DiffAddedFg">#90EE90</Color>
    <Color x:Key="Tag.DiffRemovedBg">#CC5B1E1E</Color>
    <Color x:Key="Tag.DiffRemovedFg">#FF8888</Color>

    <!-- ============ v0.11: 选择边框（多选/键盘焦点/选中态） ============ -->
    <Color x:Key="Select.CheckBg">#AA000000</Color>
    <Color x:Key="Select.CheckBorder">#E6FFFFFF</Color>
    <Color x:Key="Select.CheckFilled">#4FC3F7</Color>
    <Color x:Key="Select.CheckFilledBorder">#FFFFFF</Color>
    <Color x:Key="Select.CheckTickFg">#0A0E1A</Color>

    <!-- 渐变 -->
    <LinearGradientBrush x:Key="Gradient.Header" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#0A0E1A"/>
        <GradientStop Offset="1" Color="#161B2E"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Gradient.PrimaryButton" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="#7E57C2"/>
        <GradientStop Offset="1" Color="#B388FF"/>
    </LinearGradientBrush>

    <!-- 字体 -->
    <FontFamily x:Key="Font.Primary">Inter, "PingFang SC", "Microsoft YaHei", sans-serif</FontFamily>
    <FontFamily x:Key="Font.Mono">"JetBrains Mono", "SF Mono", Consolas, monospace</FontFamily>

    <!-- 间距 -->
    <x:Double x:Key="Space.1">4</x:Double>
    <x:Double x:Key="Space.2">8</x:Double>
    <x:Double x:Key="Space.3">12</x:Double>
    <x:Double x:Key="Space.4">16</x:Double>
    <x:Double x:Key="Space.5">24</x:Double>
    <x:Double x:Key="Space.6">32</x:Double>
    <x:Double x:Key="Space.7">48</x:Double>

    <!-- 圆角 -->
    <CornerRadius x:Key="Radius.Small">4</CornerRadius>
    <CornerRadius x:Key="Radius.Medium">6</CornerRadius>
    <CornerRadius x:Key="Radius.Large">8</CornerRadius>
    <!-- v0.11 spec §2.2：segment 段控件外框与 count 椭圆胶囊复用的圆角 token。Pill 为椭圆观感，segment 由模板内 margin/padding 决定具体形状。 -->
    <CornerRadius x:Key="Radius.Pill">9999</CornerRadius>
    <CornerRadius x:Key="Radius.Segment">6</CornerRadius>

    <!-- 动效时长 -->
    <x:Double x:Key="Duration.Fast">120</x:Double>
    <x:Double x:Key="Duration.Normal">200</x:Double>
    <x:Double x:Key="Duration.Slow">320</x:Double>

</ResourceDictionary>
