<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <SolidColorBrush x:Key="AppBackgroundBrush" Color="#000000"/>
  <SolidColorBrush x:Key="SurfaceBrush" Color="#1E1E1F"/>
  <SolidColorBrush x:Key="InputBrush" Color="#141415"/>
  <SolidColorBrush x:Key="PrimaryTextBrush" Color="#E1E1E3"/>
  <SolidColorBrush x:Key="SecondaryTextBrush" Color="#858585"/>
  <SolidColorBrush x:Key="AccentBrush" Color="#A53E42"/>
  <SolidColorBrush x:Key="AccentVariantBrush" Color="#7A2B32"/>
  <SolidColorBrush x:Key="AccentSoftBrush" Color="#3F1B1C"/>
  <SolidColorBrush x:Key="DividerBrush" Color="#3F3F46"/>
  <SolidColorBrush x:Key="ThemeGlyphBrush" Color="#FDB813"/>
  <SolidColorBrush x:Key="ProgressDialogBackgroundBrush" Color="#1B1D24"/>
  <SolidColorBrush x:Key="ProgressDialogBorderBrush" Color="#333333"/>
  <SolidColorBrush x:Key="ProgressDialogTextBrush" Color="#E1E1E3"/>
  <SolidColorBrush x:Key="ProgressDialogTrackBrush" Color="#2A2C33"/>
  <SolidColorBrush x:Key="ProgressDialogBarBrush" Color="#A53E42"/>
  <Thickness x:Key="ProgressDialogBorderThickness">0</Thickness>

  <!-- Alert 颜色 -->
  <SolidColorBrush x:Key="AlertSuccessBrush" Color="#CC000000"/>
  <SolidColorBrush x:Key="AlertErrorBrush" Color="#E74C3C"/>
  <SolidColorBrush x:Key="AlertInfoBrush" Color="#DD181B25"/>
</ResourceDictionary>
