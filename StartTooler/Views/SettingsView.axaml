<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StartTooler.ViewModels"
             xmlns:converters="using:StartTooler.Converters"
             x:Class="StartTooler.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <UserControl.Resources>
        <converters:StringNullOrEmptyToTextConverter x:Key="NullOrEmptyToPlaceholder"/>
        <converters:StringNullOrEmptyToPlaceholderClassConverter x:Key="NullOrEmptyToPlaceholderClass"/>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,Auto,*">
        <!-- Tab 栏 -->
        <Border Grid.Row="0" Background="{DynamicResource Bg.Outer}" Height="44">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="24" VerticalAlignment="Center">
                <Button Content="通用" Classes="tab-item"
                        Classes.active="{Binding SelectedTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:SettingsTab.General}}"
                        Command="{Binding SelectTabCommand}"
                        CommandParameter="{x:Static vm:SettingsTab.General}"/>
                <Button Content="OSS配置" Classes="tab-item"
                        Classes.active="{Binding SelectedTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:SettingsTab.Oss}}"
                        Command="{Binding SelectTabCommand}"
                        CommandParameter="{x:Static vm:SettingsTab.Oss}"/>
                <Button Content="AI" Classes="tab-item"
                        Classes.active="{Binding SelectedTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:SettingsTab.Anthropic}}"
                        Command="{Binding SelectTabCommand}"
                        CommandParameter="{x:Static vm:SettingsTab.Anthropic}"/>
            </StackPanel>
        </Border>

        <!-- 状态行（仅在有 StatusMessage 时显示） -->
        <Border Grid.Row="1" Padding="40,6"
                Background="{DynamicResource Bg.Outer}"
                IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="12"
                       Foreground="{DynamicResource State.Warning}"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- 底部分隔线 -->
        <Border Grid.Row="2" Height="1" Background="{DynamicResource Bg.Divider}"/>

        <!-- 表单内容 -->
        <Border Grid.Row="3" Background="{DynamicResource Bg.Surface}">
         <Panel>
            <!-- 通用 Tab -->
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,*"
                  IsVisible="{Binding SelectedTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:SettingsTab.General}}">
                <!-- 项目目录 FormRow -->
                <Border Grid.Row="0" Padding="40,16" Background="{DynamicResource Bg.Surface}">
                    <Grid ColumnDefinitions="160,*" Height="64">
                        <TextBlock Grid.Column="0" Text="项目目录"
                                   FontSize="13" Foreground="{DynamicResource Text.Primary}"
                                   VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <Button x:Name="SelectButton"
                                    MinWidth="280" Height="36"
                                    HorizontalAlignment="Left"
                                    HorizontalContentAlignment="Stretch"
                                    Classes="select-button">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding SelectedProjectDirectory, Converter={StaticResource NullOrEmptyToPlaceholder}, ConverterParameter=选择项目目录}"
                                               FontSize="13"
                                               TextTrimming="CharacterEllipsis"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               Classes.placeholder="{Binding SelectedProjectDirectory, Converter={StaticResource NullOrEmptyToPlaceholderClass}}">
                                        <TextBlock.Styles>
                                            <Style Selector="TextBlock.placeholder">
                                                <Setter Property="Foreground" Value="{DynamicResource Text.Tertiary}"/>
                                            </Style>
                                            <Style Selector="TextBlock:not(.placeholder)">
                                                <Setter Property="Foreground" Value="{DynamicResource Text.Primary}"/>
                                            </Style>
                                        </TextBlock.Styles>
                                    </TextBlock>
                                    <Path Grid.Column="1"
                                          Data="{DynamicResource Icon.ChevronDown}"
                                          Stretch="Uniform"
                                          Width="12" Height="12"
                                          Fill="{DynamicResource Text.Secondary}"
                                          VerticalAlignment="Center"
                                          Margin="8,0,0,0"/>
                                </Grid>
                                <Button.Flyout>
                                    <MenuFlyout Placement="BottomEdgeAlignedLeft">
                                        <MenuItem Header="浏览..."
                                                  Command="{Binding BrowseDirectoryCommand}"/>
                                        <Separator/>
                                        <StackPanel IsVisible="{Binding RecentDirectories.Count}">
                                            <TextBlock Text="最近使用" FontWeight="SemiBold" Foreground="{DynamicResource Text.Secondary}" Padding="8,4"/>
                                            <MenuItem Header="/Users/hex/Pictures/Test"
                                                     IsVisible="False"/>
                                            <Separator/>
                                        </StackPanel>
                                        <MenuItem Header="清空最近"
                                                  Command="{Binding ClearRecentDirectoriesCommand}"
                                                  IsEnabled="{Binding RecentDirectories.Count}"/>
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>

                            <Button Content="浏览..."
                                    Classes="secondary-button"
                                    Command="{Binding BrowseDirectoryCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 主题模式 FormRow -->
                <Border Grid.Row="1" Padding="40,16" Background="{DynamicResource Bg.Surface}">
                    <Grid ColumnDefinitions="160,*" Height="64">
                        <TextBlock Grid.Column="0" Text="主题模式"
                                   FontSize="13" Foreground="{DynamicResource Text.Primary}"
                                   VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  Width="200"
                                  SelectedIndex="{Binding SelectedTheme, Mode=TwoWay}"
                                  VerticalAlignment="Center">
                            <ComboBoxItem Content="Deep Space"/>
                            <ComboBoxItem Content="Red Night Vision"/>
                        </ComboBox>
                    </Grid>
                </Border>

                <!-- FFmpeg 路径 FormRow -->
                <Border Grid.Row="2" Padding="40,16" Background="{DynamicResource Bg.Surface}">
                    <Grid ColumnDefinitions="160,*" Height="64">
                        <TextBlock Grid.Column="0" Text="FFmpeg 路径"
                                   FontSize="13" Foreground="{DynamicResource Text.Primary}"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <TextBox Text="{Binding FfmpegPath, Mode=TwoWay}"
                                     FontSize="13"
                                     Watermark="留空走 PATH（如 /Users/you/.local/bin/ffmpeg）"
                                     Width="360"
                                     VerticalAlignment="Center"/>
                            <Button Content="浏览..."
                                    Classes="secondary-button"
                                    Command="{Binding BrowseFFmpegCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- FFprobe 路径 FormRow -->
                <Border Grid.Row="3" Padding="40,16" Background="{DynamicResource Bg.Surface}">
                    <Grid ColumnDefinitions="160,*" Height="64">
                        <TextBlock Grid.Column="0" Text="FFprobe 路径"
                                   FontSize="13" Foreground="{DynamicResource Text.Primary}"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <TextBox Text="{Binding FfprobePath, Mode=TwoWay}"
                                     FontSize="13"
                                     Watermark="留空走 PATH（如 /Users/you/.local/bin/ffprobe）"
                                     Width="360"
                                     VerticalAlignment="Center"/>
                            <Button Content="浏览..."
                                    Classes="secondary-button"
                                    Command="{Binding BrowseFFprobeCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 空区域填充 -->
                <Border Grid.Row="4" Background="{DynamicResource Bg.Surface}"/>
            </Grid>

            <!-- OSS Tab -->
            <StackPanel IsVisible="{Binding SelectedTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:SettingsTab.Oss}}">
                <!-- 供应商（未来扩展入口） -->
                <Border Padding="40,16" Background="{DynamicResource Bg.Surface}">
                    <Grid ColumnDefinitions="160,*" Height="64">
                        <TextBlock Grid.Column="0" Text="供应商"
                                   FontSize="13" Foreground="{DynamicResource Text.Primary}"
                                   VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  Width="200"
                                  SelectedIndex="{Binding OssProvider, Mode=TwoWay}"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Left"
                                  IsHitTestVisible="False">
                            <ComboBoxItem Content="阿里云 OSS"/>
                        </ComboBox>
                    </Grid>
                </Border>

                <!-- 区域 (endpoint) -->
                <Border Padding="40,16" Background="{DynamicResource Bg.Surface}">
                    <Grid ColumnDefinitions="160,*" Height="64">
                        <TextBlock Grid.Column="0" Text="区域 (endpoint)"
                                   FontSize="13" Foreground="{DynamicResource Text.Primary}"
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding OssRegion, Mode=TwoWay}"
                                 FontSize="13"
                                 Watermark="cn-hangzhou"
                                 VerticalAlignment="Center"
                                 Width="360" HorizontalAlignment="Left"/>
                    </Grid>
                </Border>

                <!-- 桶名 (bucket) -->
                <Border Padding="40,16" Background="{DynamicResource Bg.Surface}">
                    <Grid ColumnDefinitions="160,*" Height="64">
                        <TextBlock Grid.Column="0" Text="桶名(bucket)"
                                   FontSize="13" Foreground="{DynamicResource Text.Primary}"
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding OssBucket, Mode=TwoWay}"
                                 FontSize="13"
                                 Watermark="my-photos"
                                 VerticalAlignment="Center"
                                 Width="360" HorizontalAlignment="Left"/>
                    </Grid>
                </Border>

                <!-- 密钥 (access key) -->
                <Border Padding="40,16" Background="{DynamicResource Bg.Surface}">
                    <Grid ColumnDefinitions="160,*" Height="64">
                        <TextBlock Grid.Column="0" Text="密钥 (access key)"
                                   FontSize="13" Foreground="{DynamicResource Text.Primary}"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <TextBox Text="{Binding OssAccessKey, Mode=TwoWay}"
                                     FontSize="13"
                                     Watermark="AccessKeyId"
                                     Width="280"
                                     VerticalAlignment="Center"/>
                            <TextBox Text="{Binding OssSecretKey, Mode=TwoWay}"
                                     FontSize="13"
                                     PasswordChar="•"
                                     Watermark="AccessKeySecret"
                                     Width="280"
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 路径前缀 -->
                <Border Padding="40,16" Background="{DynamicResource Bg.Surface}">
                    <Grid ColumnDefinitions="160,*" Height="64">
                        <TextBlock Grid.Column="0" Text="路径前缀"
                                   FontSize="13" Foreground="{DynamicResource Text.Primary}"
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding OssPathPrefix, Mode=TwoWay}"
                                 FontSize="13"
                                 Watermark="astrophotos/（可选）"
                                 VerticalAlignment="Center"
                                 Width="360" HorizontalAlignment="Left"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Anthropic AI Tab -->
            <StackPanel IsVisible="{Binding SelectedTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:SettingsTab.Anthropic}}">
                <!-- 说明横幅 -->
                <Border Padding="40,16" Background="{DynamicResource Bg.Surface}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Anthropic Claude 大模型配置"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Text.Primary}"/>
                        <TextBlock TextWrapping="Wrap"
                                   FontSize="12"
                                   Foreground="{DynamicResource Text.Secondary}"
                                   Text="在 https://console.anthropic.com/ 申请 API Key。Key 仅保存在本地 config.db，不上传任何服务。BaseUrl 默认官方，私有化部署时改这里。"/>
                    </StackPanel>
                </Border>

                <!-- API Key -->
                <Border Padding="40,16" Background="{DynamicResource Bg.Surface}">
                    <Grid ColumnDefinitions="160,*" Height="64">
                        <TextBlock Grid.Column="0" Text="API Key"
                                   FontSize="13" Foreground="{DynamicResource Text.Primary}"
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding AnthropicApiKey, Mode=TwoWay}"
                                 FontSize="13"
                                 PasswordChar="•"
                                 Watermark="sk-ant-..."
                                 VerticalAlignment="Center"
                                 Width="420" HorizontalAlignment="Left"/>
                    </Grid>
                </Border>

                <!-- Base URL -->
                <Border Padding="40,16" Background="{DynamicResource Bg.Surface}">
                    <Grid ColumnDefinitions="160,*" Height="64">
                        <TextBlock Grid.Column="0" Text="Base URL"
                                   FontSize="13" Foreground="{DynamicResource Text.Primary}"
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding AnthropicBaseUrl, Mode=TwoWay}"
                                 FontSize="13"
                                 Watermark="https://api.anthropic.com"
                                 VerticalAlignment="Center"
                                 Width="420" HorizontalAlignment="Left"/>
                    </Grid>
                </Border>

                <!-- Model -->
                <Border Padding="40,16" Background="{DynamicResource Bg.Surface}">
                    <Grid ColumnDefinitions="160,*" Height="64">
                        <TextBlock Grid.Column="0" Text="模型"
                                   FontSize="13" Foreground="{DynamicResource Text.Primary}"
                                   VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  Width="420"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center"
                                  IsEditable="True"
                                  Text="{Binding AnthropicModel, Mode=TwoWay}">
                            <ComboBoxItem Content="claude-3-5-sonnet-latest"/>
                            <ComboBoxItem Content="claude-3-5-haiku-latest"/>
                            <ComboBoxItem Content="claude-3-opus-latest"/>
                            <ComboBoxItem Content="claude-3-5-sonnet-20241022"/>
                            <ComboBoxItem Content="claude-3-5-haiku-20241022"/>
                            <ComboBoxItem Content="claude-3-opus-20240229"/>
                        </ComboBox>
                    </Grid>
                </Border>
            </StackPanel>
         </Panel>
        </Border>
    </Grid>
</UserControl>
