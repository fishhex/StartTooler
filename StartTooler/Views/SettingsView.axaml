<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StartTooler.ViewModels"
             x:Class="StartTooler.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <Grid RowDefinitions="Auto,*">
        <!-- Tab 栏 -->
        <Border Grid.Row="0" Background="{DynamicResource Bg.Outer}" Height="44">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="24">
                <Button Content="项目" Classes="tab-item" IsEnabled="False"/>
                <Button Content="OSS配置" Classes="tab-item"/>
            </StackPanel>
        </Border>

        <!-- 表单内容 -->
        <Border Grid.Row="1" Background="{DynamicResource Bg.Surface}" Padding="32">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto">
                <!-- 项目目录 -->
                <Grid Grid.Row="0" ColumnDefinitions="120,*" Height="56" Margin="0,8">
                    <TextBlock Grid.Column="0" Text="项目目录"
                               FontSize="13" Foreground="{DynamicResource Text.Primary}"
                               VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding AvailableDirectories}"
                              SelectedItem="{Binding SelectedProjectDirectory}"
                              Height="36" MinWidth="240"
                              HorizontalAlignment="Left"/>
                </Grid>

                <!-- 分割线 -->
                <Border Grid.Row="1" Height="1" Background="{DynamicResource Bg.Divider}" Margin="0,8"/>

                <!-- 主题切换 -->
                <Grid Grid.Row="2" ColumnDefinitions="120,*" Height="56" Margin="0,8">
                    <TextBlock Grid.Column="0" Text="主题模式"
                               FontSize="13" Foreground="{DynamicResource Text.Primary}"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <RadioButton Content="Deep Space" GroupName="Theme"
                                     IsChecked="{Binding IsDeepSpaceTheme}"
                                     Foreground="{DynamicResource Text.Primary}" FontSize="13"/>
                        <RadioButton Content="Red Night Vision" GroupName="Theme"
                                     IsChecked="{Binding IsRedNightTheme}"
                                     Foreground="{DynamicResource Text.Primary}" FontSize="13"/>
                    </StackPanel>
                </Grid>

                <!-- 分割线 -->
                <Border Grid.Row="3" Height="1" Background="{DynamicResource Bg.Divider}" Margin="0,8"/>

                <!-- 状态消息 -->
                <TextBlock Grid.Row="4" Text="{Binding StatusMessage}"
                           FontSize="12" Foreground="{DynamicResource Text.Secondary}"
                           VerticalAlignment="Bottom" Margin="0,16"/>

                <!-- 保存按钮 -->
                <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="12">
                    <TextBlock Text="有未保存的修改"
                               FontSize="11" Foreground="{DynamicResource Text.Secondary}"
                               VerticalAlignment="Center"
                               IsVisible="{Binding IsDirty}"/>
                    <Button Content="保存"
                            Classes="primary-button"
                            Command="{Binding SaveCommand}"
                            IsEnabled="{Binding IsDirty}"
                            Height="36" Width="80"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
