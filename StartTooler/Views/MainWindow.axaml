<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:StartTooler.ViewModels"
        xmlns:converters="using:StartTooler.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="StartTooler.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="媒体文件扫描工具">

    <Window.Resources>
        <converters:ThumbnailPathToBitmapConverter x:Key="ThumbnailConverter"/>
    </Window.Resources>

    <Window.Styles>
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>
    </Window.Styles>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*">
        <!-- 顶部工具栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10" Spacing="10">
            <Button Content="选择文件夹" 
                    Click="OnSelectFolderButton_Click"
                    Padding="15,8"
                    FontSize="14"/>
            <TextBlock Text="{Binding SelectedFolderPath}" 
                       VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="Gray"/>
        </StackPanel>

        <!-- 状态栏 -->
        <Border Grid.Row="1" Background="#F5F5F5" Padding="10,5">
            <TextBlock Text="{Binding StatusMessage}" 
                       FontSize="12"
                       Foreground="#666666"/>
        </Border>

        <!-- 文件列表 -->
        <DataGrid Grid.Row="2" 
                  ItemsSource="{Binding MediaFiles}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  Margin="10">
            <DataGrid.Columns>
                <!-- 缩略图列 -->
                <DataGridTemplateColumn Header="预览" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Width="80" Height="60" Stretch="UniformToFill">
                                <Image.Source>
                                    <Binding Path="ThumbnailPath" Converter="{StaticResource ThumbnailConverter}"/>
                                </Image.Source>
                            </Image>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                
                <DataGridTextColumn Header="文件名" 
                                    Binding="{Binding FileName}"
                                    Width="2*"/>
                <DataGridTextColumn Header="类型" 
                                    Binding="{Binding FileType}"
                                    Width="*"/>
                <DataGridTextColumn Header="大小" 
                                    Binding="{Binding FormattedFileSize}"
                                    Width="*"/>
                <DataGridTextColumn Header="修改时间" 
                                    Binding="{Binding ModifiedTime, StringFormat='yyyy-MM-dd HH:mm:ss'}"
                                    Width="2*"/>
                <DataGridTextColumn Header="路径" 
                                    Binding="{Binding FilePath}"
                                    Width="3*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>

</Window>
