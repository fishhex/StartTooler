<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:StartTooler.ViewModels"
        xmlns:views="using:StartTooler.Views"
        xmlns:components="using:StartTooler.Components"
        xmlns:controls="using:StartTooler.Controls"
        xmlns:services="using:StartTooler.Services"
        xmlns:converters="using:StartTooler.Converters"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="StartTooler.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding WindowTitle}"
        Width="1200"
        Height="800"
        MinWidth="800"
        MinHeight="500"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="38"
        SystemDecorations="Full"
        Background="{DynamicResource Bg.Outer}"
        DragDrop.AllowDrop="True">

    <Window.Resources>
        <!-- v0.11 spec/09 §3.1: 网络状态 Converter -->
        <converters:BoolToNetworkColorConverter x:Key="BoolToNetworkColor"/>
        <converters:BoolToNetworkTextConverter x:Key="BoolToNetworkText"/>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>

    <!-- v2.3 布局（v0.11 加状态栏）：
         Col 0: NavRail (80px)        Col 1: 内容
         Row 0: 标题栏 (38px, 跨两列)
         Row 1: 工具栏 (40px)         (NavRail 顶部留白 40px)
         Row 2: 页面内容 (*)          NavRail 主体
         Row 3: 状态栏 (28px)         跨两列 (spec demand/06 §9) -->
    <Window.KeyBindings>
        <!-- v0.11: NavRail 快捷键 (spec demand/06 §4. 无键盘快捷键) -->
        <KeyBinding Gesture="Ctrl+1" Command="{Binding NavigateToMediaCommand}"/>
        <KeyBinding Gesture="Ctrl+2" Command="{Binding NavigateToUploadServerCommand}"/>
        <KeyBinding Gesture="Ctrl+3" Command="{Binding NavigateToTrashCommand}"/>
        <KeyBinding Gesture="Ctrl+4" Command="{Binding NavigateToSettingsCommand}"/>
    </Window.KeyBindings>
    <Grid ColumnDefinitions="80,*"
          RowDefinitions="38,40,*,28">
        <!-- Row 0 跨两列: 系统标题栏 -->
        <Panel Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0"
               x:Name="TitleBar"
               Background="Transparent"
               PointerPressed="OnTitleBarPointerPressed">
            <Border Background="{DynamicResource Bg.Outer}"
                    BorderBrush="{DynamicResource Bg.Divider}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="80,0,0,0">
                    <TextBlock Text="星助"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Text.Primary}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
            <!-- v0.12: 扫描进度改用 NotificationCard 通知（spec doc/16-notify-progress.md §3.3），不再常驻底部进度条 -->
        </Panel>

        <!-- Row 1 Col 0: NavRail 上方 40px 留白 (背景色与 NavRail 一致) -->
        <Border Grid.Column="0" Grid.Row="1"
                Background="{DynamicResource Bg.Outer}"
                BorderBrush="{DynamicResource Bg.Divider}"
                BorderThickness="0,0,1,1"/>

        <!-- Row 1 Col 1: 全局工具栏 -->
        <Border Grid.Column="1" Grid.Row="1"
                Background="{DynamicResource Bg.Surface}"
                BorderBrush="{DynamicResource Bg.Divider}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <!-- 最右：返回按钮（设置页 / 垃圾筒页，v0.11 加 ← 箭头 spec demand/06 §9.） -->
                <Button Classes="secondary-button"
                        DockPanel.Dock="Right"
                        Margin="0,0,16,0"
                        Command="{Binding NavigateToMediaCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <!-- 左箭头 ← Path -->
                        <Path Data="M16,0 L6,8 L16,16"
                              Stretch="Uniform"
                              Width="10" Height="10"
                              Stroke="{DynamicResource Text.Secondary}"
                              StrokeThickness="2"
                              Fill="Transparent"
                              VerticalAlignment="Center"/>
                        <TextBlock Text="返回"
                                   FontSize="12"
                                   Foreground="{DynamicResource Text.Primary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.Or}">
                            <Binding Path="IsSettingsPageVisible"/>
                            <Binding Path="IsTrashActive"/>
                        </MultiBinding>
                    </Button.IsVisible>
                </Button>

                <!-- 次右：保存按钮（设置页）—— v0.11 §3.3 Content 绑 SaveButtonText（"保存" ↔ "已保存 ✓"） -->
                <Button Classes="secondary-button"
                        DockPanel.Dock="Right"
                        Margin="0,0,8,0"
                        Content="{Binding SettingsViewModel.SaveButtonText}"
                        Command="{Binding SettingsViewModel.SaveCommand}"
                        IsEnabled="{Binding SettingsViewModel.IsDirty}"
                        IsVisible="{Binding IsSettingsPageVisible}"/>

                <!-- 右侧：刷新按钮（媒体页） -->
                <Button Classes="refresh-button"
                        DockPanel.Dock="Right"
                        Margin="0,0,16,0"
                        Command="{Binding GalleryViewModel.RefreshCommand}"
                        IsEnabled="{Binding GalleryViewModel.ProjectPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        ToolTip.Tip="刷新扫描"
                        IsVisible="{Binding IsGalleryPage}">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Path Data="{DynamicResource Icon.Refresh}"
                              Stretch="Uniform"
                              Width="14" Height="14"
                              Fill="{DynamicResource Text.Secondary}"
                              Classes="refresh-icon"/>
                        <TextBlock Text="刷新"
                                   FontSize="12"
                                   Foreground="{DynamicResource Text.Secondary}"
                                   VerticalAlignment="Center"
                                   Classes="refresh-text"/>
                    </StackPanel>
                </Button>

                <!-- 排序 ComboBox（v0.6 / v0.11 加 ↑↓ 图标 spec demand/06 §8.） -->
                <ComboBox DockPanel.Dock="Right"
                          SelectedIndex="{Binding GalleryViewModel.SortModeIndex}"
                          IsVisible="{Binding IsGalleryPage}"
                          ToolTip.Tip="排序方式"
                          Classes="sort-combo"
                          Width="100"
                          Margin="0,0,8,0">
                    <ComboBoxItem>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Path Data="M7,4 L7,16 M4,7 L7,4 L10,7 M2,18 L13,18"
                                  Stroke="{DynamicResource Text.Secondary}"
                                  StrokeThickness="1.5"
                                  Fill="Transparent"
                                  Width="14" Height="14"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="时间" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ComboBoxItem>
                    <ComboBoxItem>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Path Data="M12,2 L15,8 L22,9 L17,14 L18,21 L12,18 L6,21 L7,14 L2,9 L9,8 Z"
                                  Stroke="{DynamicResource Text.Secondary}"
                                  StrokeThickness="1.5"
                                  Fill="Transparent"
                                  Width="14" Height="14"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="评分" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ComboBoxItem>
                </ComboBox>

                <!-- 左侧：动作按钮组（媒体页） -->
                <StackPanel Orientation="Horizontal"
                            Spacing="8"
                            Margin="16,0,0,0"
                            VerticalAlignment="Center"
                            IsVisible="{Binding IsGalleryPage}">
                    <Button Classes="toolbar-button"
                            Content="多选"
                            Command="{Binding GalleryViewModel.EnterMultiSelectCommand}"
                            IsVisible="{Binding !GalleryViewModel.IsMultiSelectMode}"
                            IsEnabled="{Binding !GalleryViewModel.IsUploading}"/>

                    <Button Classes="toolbar-button"
                            Content="取消多选"
                            Command="{Binding GalleryViewModel.ExitMultiSelectCommand}"
                            IsVisible="{Binding GalleryViewModel.IsMultiSelectMode}"/>

                    <Button Classes="toolbar-button"
                            Content="全选"
                            Command="{Binding GalleryViewModel.SelectAllCommand}"
                            ToolTip.Tip="全选当前日期"
                            IsVisible="{Binding GalleryViewModel.IsMultiSelectMode}"/>

                    <Button Classes="toolbar-button"
                            Content="反选"
                            Command="{Binding GalleryViewModel.InvertSelectionCommand}"
                            ToolTip.Tip="反选当前日期"
                            IsVisible="{Binding GalleryViewModel.IsMultiSelectMode}"/>

                    <Button Classes="toolbar-button"
                            Content="批量上传"
                            Command="{Binding GalleryViewModel.BatchUploadCommand}"
                            IsEnabled="{Binding GalleryViewModel.IsBatchActionEnabled}"
                            IsVisible="{Binding GalleryViewModel.IsMultiSelectMode}"/>

                    <!--
                      v0.11: 工具栏多选按钮收拢（spec §4）——
                      把「批量下载 / 释放本地空间」从主条移到 "更多 ▾" 下拉，保留核心 6 个按钮
                      主条顺序：取消多选 | 全选 | 批量上传 | 开始AI | 编辑标签 | 删除 | 更多 ▾
                    -->
                    <Button Classes="toolbar-button"
                            Content="更多 ▾"
                            IsVisible="{Binding GalleryViewModel.IsMultiSelectMode}"
                            Margin="6,0,0,0">
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Header="反选"
                                          Command="{Binding GalleryViewModel.InvertSelectionCommand}" />
                                <MenuItem Header="批量下载"
                                          Command="{Binding GalleryViewModel.BatchDownloadCommand}" />
                                <MenuItem Header="释放本地空间"
                                          Command="{Binding GalleryViewModel.BatchFreeUpSpaceCommand}" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>

                    <Button Classes="toolbar-button-danger"
                            Content="删除"
                            Command="{Binding GalleryViewModel.BatchDeleteCommand}"
                            IsEnabled="{Binding GalleryViewModel.IsBatchActionEnabled}"
                            IsVisible="{Binding GalleryViewModel.IsMultiSelectMode}"/>

                    <!-- v0.6: 开始AI 按钮（多选模式下显示，受 IsBatchActionEnabled 控制） -->
                    <Button Classes="toolbar-button"
                            Command="{Binding GalleryViewModel.BatchTagCommand}"
                            IsEnabled="{Binding GalleryViewModel.IsBatchActionEnabled}"
                            IsVisible="{Binding GalleryViewModel.IsMultiSelectMode}">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Path Data="{DynamicResource Icon.Sparkles}"
                                  Width="14" Height="14"
                                  Fill="{DynamicResource Text.Secondary}"
                                  Stretch="Uniform"/>
                            <TextBlock Text="开始AI"/>
                        </StackPanel>
                    </Button>

                    <!-- v0.12: 编辑标签按钮（多选模式下显示，IsBatchActionEnabled 包含 !IsTagging） -->
                    <Button Classes="toolbar-button"
                            Command="{Binding GalleryViewModel.EditTagsBatchCommand}"
                            IsEnabled="{Binding GalleryViewModel.IsBatchActionEnabled}"
                            IsVisible="{Binding GalleryViewModel.IsMultiSelectMode}"
                            ToolTip.Tip="编辑选中文件的标签（替换 / 追加 / 删除）">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Path Data="{StaticResource Icon.Pencil}"
                                  Width="14" Height="14"
                                  Fill="{DynamicResource Text.Secondary}"
                                  Stretch="Uniform"/>
                            <TextBlock Text="编辑标签"/>
                        </StackPanel>
                    </Button>

                    <!-- 上传中：取消按钮 + 进度文本 -->
                    <Button Classes="toolbar-button-danger"
                            Content="取消上传"
                            Command="{Binding GalleryViewModel.CancelUploadCommand}"
                            IsVisible="{Binding GalleryViewModel.IsUploading}"/>

                    <!-- v0.6: 打标中：取消按钮（v0.12 进度文本改用 NotificationCard 通知） -->
                    <Button Classes="toolbar-button-danger"
                            Content="取消打标"
                            Command="{Binding GalleryViewModel.CancelTagCommand}"
                            IsVisible="{Binding GalleryViewModel.IsTagging}"/>

                    <!-- v0.12: TagProgressText / UploadProgressText TextBlock 删除，改用 NotificationCard 通知（spec doc/16-notify-progress.md §3.1 §3.2） -->

                    <TextBlock Text="{Binding GalleryViewModel.SelectedCount, StringFormat='已选 {0} 项'}"
                               FontSize="12"
                               Foreground="{DynamicResource Text.Secondary}"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"
                               IsVisible="{Binding GalleryViewModel.IsMultiSelectMode}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Row 2 Col 0: NavRail 主体 -->
        <Border Grid.Column="0" Grid.Row="2"
                Background="{DynamicResource Bg.Outer}"
                BorderBrush="{DynamicResource Bg.Divider}"
                BorderThickness="0,0,1,0">
            <controls:NavRail DataContext="{Binding}"/>
        </Border>

        <!-- Row 2 Col 1: 页面内容（v0.11 用 TransitioningContentControl 加 PageSlide 过渡，spec demand/06 §10.） -->
        <TransitioningContentControl Grid.Column="1" Grid.Row="2" Content="{Binding CurrentView}">
            <TransitioningContentControl.PageTransition>
                <PageSlide Duration="0:0:0.24" Orientation="Horizontal"/>
            </TransitioningContentControl.PageTransition>
            <TransitioningContentControl.DataTemplates>
                <DataTemplate DataType="{x:Type vm:GalleryViewModel}">
                    <views:GalleryView DataContext="{Binding}"/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                    <views:SettingsView DataContext="{Binding}"/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:UploadServerViewModel}">
                    <views:UploadServerView DataContext="{Binding}"/>
                </DataTemplate>
                <!-- v0.8: 垃圾筒页（spec §9.3） -->
                <DataTemplate DataType="{x:Type vm:TrashViewModel}">
                    <views:TrashView DataContext="{Binding}"/>
                </DataTemplate>
            </TransitioningContentControl.DataTemplates>
        </TransitioningContentControl>

        <!-- 右下角通知浮层（跨全窗口） -->
        <Panel Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2"
               IsHitTestVisible="False"
               HorizontalAlignment="Right"
               VerticalAlignment="Bottom"
               Margin="0,0,0,16">
            <ItemsControl ItemsSource="{Binding Source={x:Static services:NotificationService.Current}, Path=Items}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" Spacing="0"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="services:NotificationItem">
                        <views:NotificationCard/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Panel>

        <!-- v0.11 状态栏（spec demand/06 §12. 无状态栏）跨两列 28px -->
        <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="3"
                Background="{DynamicResource Bg.Outer}"
                BorderBrush="{DynamicResource Bg.Divider}"
                BorderThickness="0,1,0,0"
                Padding="16,0">
            <DockPanel>
                <!-- 左侧：已上传 / 当前文件数（仅 Gallery 页显示） -->
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding GalleryViewModel.UploadedFileStat}"
                           FontSize="11"
                           Foreground="{DynamicResource Text.Secondary}"
                           VerticalAlignment="Center"/>

                <!-- 中间：上次刷新时间（仅 Gallery 页显示） -->
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding GalleryViewModel.LastRefreshText}"
                           FontSize="11"
                           Foreground="{DynamicResource Text.Disabled}"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0">
                    <TextBlock.IsVisible>
                        <Binding Path="IsGalleryPage"/>
                    </TextBlock.IsVisible>
                </TextBlock>

                <!-- v0.11 spec/10 §4.1: 大图库提示（> 2000 张时显示，null 时隐藏） -->
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding LargeLibraryHint}"
                           FontSize="11"
                           Foreground="{DynamicResource Text.Tertiary}"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"
                           IsVisible="{Binding LargeLibraryHint, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                <!-- v0.11: 状态栏通知历史 🔔 入口（spec §14.2） -->
                <Button DockPanel.Dock="Right"
                        Classes="toolbar-button"
                        ToolTip.Tip="通知历史"
                        Margin="0,0,12,0"
                        Padding="6,2">
                    <Button.Flyout>
                        <Flyout Placement="Top">
                            <Border MinWidth="280" MaxWidth="360" MaxHeight="400"
                                    Background="{DynamicResource Bg.SurfaceElevated}"
                                    CornerRadius="{DynamicResource Radius.Medium}"
                                    Padding="8">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="通知历史"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource Text.Primary}"
                                               Margin="0,0,0,8" />
                                    <ScrollViewer MaxHeight="360">
                                        <ItemsControl ItemsSource="{Binding NotificationHistory}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="services:NotificationItem">
                                                    <Border Background="{DynamicResource Bg.Surface}"
                                                            CornerRadius="4"
                                                            Padding="8,6"
                                                            Margin="0,2">
                                                        <StackPanel Spacing="2">
                                                            <TextBlock Text="{Binding Title}"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource Text.Primary}" />
                                                            <TextBlock Text="{Binding Body}"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource Text.Secondary}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       MaxLines="2" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                        </Flyout>
                    </Button.Flyout>
                    <PathIcon Data="{StaticResource Icon.Bell}"
                              Width="14" Height="14"
                              Foreground="{DynamicResource Text.Secondary}"/>
                </Button>

                <!-- 右侧：OSS 状态圆点 + 文字 -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Spacing="6"
                            VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8"
                             Fill="{Binding OssStatusColor}"
                             VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding OssStatusText}"
                               FontSize="11"
                               Foreground="{DynamicResource Text.Secondary}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- v0.11 spec/09 §3.1: 网络在线/离线指示器 -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Spacing="6"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0">
                    <Ellipse Width="8" Height="8"
                             Fill="{Binding IsOnline, Converter={StaticResource BoolToNetworkColor}}"
                             VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding IsOnline, Converter={StaticResource BoolToNetworkText}}"
                               FontSize="11"
                               Foreground="{DynamicResource Text.Secondary}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- v0.11 spec/09 §6.2: 状态栏磁盘空间显示 -->
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding DiskSpaceText}"
                           FontSize="11"
                           Foreground="{DynamicResource Text.Secondary}"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"
                           ToolTip.Tip="项目目录所在磁盘的可用空间"/>
            </DockPanel>
        </Border>

        <!-- v0.11 spec/06 §4.1: 全局拖拽遮罩(置顶,IsHitTestVisible=False 让事件穿透) -->
        <Border x:Name="DragDropOverlay"
                Grid.Column="0" Grid.ColumnSpan="2"
                Grid.Row="0" Grid.RowSpan="4"
                IsVisible="False"
                Background="#880A0E1A"
                ZIndex="9999"
                IsHitTestVisible="False">
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#CC1A1E2E"
                    CornerRadius="12"
                    Padding="48,32">
                <StackPanel Spacing="12" HorizontalAlignment="Center">
                    <TextBlock Text="松开以导入"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Text.Primary}"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Name="DragDropFileCount"
                               Text=""
                               FontSize="14"
                               Foreground="{DynamicResource Text.Secondary}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
