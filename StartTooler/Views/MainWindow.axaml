<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:StartTooler.ViewModels"
        xmlns:views="using:StartTooler.Views"
        xmlns:components="using:StartTooler.Components"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
        x:Class="StartTooler.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1000"
        Height="700"
        MinWidth="800"
        MinHeight="500"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="38"
        SystemDecorations="Full"
        Background="{DynamicResource Bg.Outer}">

    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>

    <Grid RowDefinitions="38,Auto,*">
        <!-- 标题栏 - Bg.Outer 背景 + 底部边框 -->
        <Border Grid.Row="0"
                Background="{DynamicResource Bg.Outer}"
                BorderBrush="{DynamicResource Bg.Divider}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                <!-- macOS 交通灯占位（系统绘制） -->
                <Border Grid.Column="0" Width="80"/>

                <!-- 刷新按钮 -->
                <Button Grid.Column="1"
                        Classes="refresh-button"
                        Command="{Binding RefreshCommand}"
                        IsEnabled="{Binding HasProject}"
                        ToolTip.Tip="刷新扫描">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Path Data="{DynamicResource Icon.Refresh}"
                              Stretch="Uniform"
                              Width="14" Height="14"
                              Fill="{DynamicResource Text.Secondary}"
                              Classes="refresh-icon"/>
                        <TextBlock Text="刷新"
                                   FontSize="12"
                                   Foreground="{DynamicResource Text.Secondary}"
                                   VerticalAlignment="Center"
                                   Classes="refresh-text"/>
                    </StackPanel>
                </Button>

                <!-- 标题 -->
                <TextBlock Grid.Column="2" Text="星助"
                           FontSize="13" FontWeight="600"
                           Foreground="{DynamicResource Text.Primary}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <!-- 设置/返回按钮 -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,0">
                    <!-- 返回按钮 (设置页显示) -->
                    <Button Content="返回"
                            Classes="header-button"
                            Command="{Binding NavigateToGalleryCommand}"
                            IsVisible="{Binding IsSettingsPage}"/>
                    <!-- 设置按钮 (非设置页显示) -->
                    <Button Content="设置"
                            Classes="header-button"
                            Command="{Binding NavigateToSettingsCommand}"
                            IsVisible="{Binding !IsSettingsPage}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 扫描进度条 -->
        <components:ScanProgressBar Grid.Row="1"
                                     DataContext="{Binding GalleryViewModel}"/>

        <!-- 内容区域 -->
        <ContentControl Grid.Row="2" Content="{Binding CurrentView}">
            <ContentControl.DataTemplates>
                <DataTemplate DataType="{x:Type vm:GalleryViewModel}">
                    <views:GalleryView DataContext="{Binding}"/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                    <views:SettingsView DataContext="{Binding}"/>
                </DataTemplate>
            </ContentControl.DataTemplates>
        </ContentControl>
    </Grid>
</Window>
