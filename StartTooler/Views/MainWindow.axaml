<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:StartTooler.ViewModels"
        xmlns:converters="using:StartTooler.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="StartTooler.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="媒体文件扫描工具">

    <Window.Resources>
        <converters:ThumbnailPathToBitmapConverter x:Key="ThumbnailConverter"/>
    </Window.Resources>

    <Window.Styles>
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>
    </Window.Styles>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*">
        <!-- 顶部工具栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10" Spacing="10">
            <Button Content="选择文件夹" 
                    Click="OnSelectFolderButton_Click"
                    Padding="15,8"
                    FontSize="14"/>
            <TextBlock Text="{Binding SelectedFolderPath}" 
                       VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="Gray"/>
        </StackPanel>

        <!-- 状态栏 -->
        <Border Grid.Row="1" Background="#F5F5F5" Padding="10,5">
            <TextBlock Text="{Binding StatusMessage}" 
                       FontSize="12"
                       Foreground="#666666"/>
        </Border>

        <!-- 媒体文件网格视图 -->
        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Disabled">
            <DockPanel>
                <ItemsControl ItemsSource="{Binding MediaFiles}" HorizontalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" ItemWidth="180" ItemHeight="220"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="164" 
                                Height="204"
                                Margin="8" 
                                BorderBrush="#E0E0E0" 
                                BorderThickness="1"
                                CornerRadius="4"
                                Background="White">
                            <Grid RowDefinitions="Auto, *, Auto, Auto">
                                
                                <Border Grid.Row="0"
                                        Height="120"
                                        Margin="10,10,10,5"
                                        Background="#F0F0F0"
                                        ClipToBounds="True">
                                    <Image Stretch="UniformToFill"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                        <Image.Source>
                                            <Binding Path="ThumbnailPath" Converter="{StaticResource ThumbnailConverter}"/>
                                        </Image.Source>
                                    </Image>
                                </Border>
                                
                                <TextBlock Grid.Row="1"
                                           Text="{Binding FileName}" 
                                           FontSize="11"
                                           FontWeight="Medium"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           MaxHeight="30"
                                           Margin="8,5,8,2"
                                           Foreground="#333333"/>
                                
                                <TextBlock Grid.Row="2"
                                           Text="{Binding FileType}" 
                                           FontSize="9"
                                           Foreground="#999999"
                                           Margin="8,0,8,2"/>
                                
                                <TextBlock Grid.Row="3"
                                           Text="{Binding FormattedFileSize}" 
                                           FontSize="9"
                                           Foreground="#999999"
                                           Margin="8,0,8,5"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </DockPanel>
    </ScrollViewer>
    </Grid>

</Window>
