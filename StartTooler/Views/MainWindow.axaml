<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:StartTooler.ViewModels"
        xmlns:views="using:StartTooler.Views"
        xmlns:components="using:StartTooler.Components"
        xmlns:controls="using:StartTooler.Controls"
        xmlns:platform="using:Avalonia.Platform"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="StartTooler.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1200"
        Height="800"
        MinWidth="800"
        MinHeight="500"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="38"
        SystemDecorations="Full"
        Background="{DynamicResource Bg.Outer}">

    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>

    <!-- 两列两行布局：Col 0: NavRail(80px) | Col 1: 内容(*) -->
    <!--                        Row 0: 标题栏(38px) | Row 1: 内容(*) -->
    <Grid ColumnDefinitions="80,*"
          RowDefinitions="38,*">
        <!-- 系统标题栏 (Row 0 跨两列) -->
        <Panel Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0"
               x:Name="TitleBar"
               Background="Transparent"
               PointerPressed="OnTitleBarPointerPressed">
            <Border Background="{DynamicResource Bg.Outer}"
                    BorderBrush="{DynamicResource Bg.Divider}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="80,0,0,0">
                    <!-- 星助标题 -->
                    <TextBlock Text="星助"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Text.Primary}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Panel>

        <!-- 扫描进度条 (C14 ScanProgressBar) -->
        <components:ScanProgressBar Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0"
                                     VerticalAlignment="Bottom"
                                     DataContext="{Binding GalleryViewModel}"/>

        <!-- 左侧导航 Rail (Col 0 仅内容区) -->
        <Border Grid.Column="0" Grid.Row="1"
                Background="{DynamicResource Bg.Outer}"
                BorderBrush="{DynamicResource Bg.Divider}"
                BorderThickness="0,0,1,0">
            <controls:NavRail DataContext="{Binding}"/>
        </Border>

        <!-- 页面内容区域 (Row 1 Col 1) -->
        <ContentControl Grid.Column="1" Grid.Row="1" Content="{Binding CurrentView}">
            <ContentControl.DataTemplates>
                <DataTemplate DataType="{x:Type vm:GalleryViewModel}">
                    <views:GalleryView DataContext="{Binding}"/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                    <views:SettingsView DataContext="{Binding}"/>
                </DataTemplate>
            </ContentControl.DataTemplates>
        </ContentControl>
    </Grid>
</Window>
