<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="StartTooler.Views.MainWindow"
        Title="StartTooler 控制中心"
        Width="900"
        Height="600"
        WindowStartupLocation="CenterScreen">

    <Border Background="#101218" Padding="30">
        <Grid RowDefinitions="Auto, *">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Image Source="/Assets/avalonia-logo.ico" Width="32" Height="32" Stretch="Uniform"/>
                <StackPanel>
                    <TextBlock Text="StartTooler" FontSize="22" FontWeight="SemiBold" Foreground="#F5F6FA"/>
                    <TextBlock Text="工具面板" FontSize="13" Foreground="#A0A4B5"/>
                </StackPanel>
            </StackPanel>

            <Border Grid.Row="1" CornerRadius="16" Background="#181B25" Padding="24">
                <Grid ColumnDefinitions="250,*" ColumnSpacing="24">
                    <StackPanel Spacing="10">
                        <TextBlock Text="模块" FontSize="14" Foreground="#7D84A0" Margin="0,0,0,4"/>
                        <Border Background="#22283A" CornerRadius="10" Padding="16" Margin="0,0,0,10">
                            <StackPanel Spacing="8">
                                <TextBlock Text="媒体管理器" FontSize="16" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                                <TextBlock Text="扫描、分组并管理本地媒体文件" TextWrapping="Wrap" Foreground="#B4BAD4" FontSize="12"/>
                                <Button Content="打开"
                                        HorizontalAlignment="Left"
                                        Padding="18,6"
                                        Background="#A53E42"
                                        Foreground="White"
                                        CornerRadius="6"
                                        Click="OnOpenMediaManagerClick"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#1F2331" CornerRadius="10" Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Text="快速说明" FontSize="13" Foreground="#EBEDF5"/>
                                <TextBlock FontSize="11" TextWrapping="Wrap" Foreground="#8E93AC">
                                    默认会自动打开媒体管理器窗口，您可以在此面板再次启动或在未来接入更多模块。
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Background="#1F2331" CornerRadius="12" Padding="20" Grid.Column="1">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                            <TextBlock Text="欢迎使用 StartTooler" FontSize="20" FontWeight="SemiBold" Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                            <TextBlock Text="媒体管理器正在单独窗口中运行" Foreground="#9CA2BE" FontSize="13" HorizontalAlignment="Center"/>
                            <Button Content="重新打开媒体管理器"
                                    Padding="22,8"
                                    Background="#A53E42"
                                    Foreground="White"
                                    CornerRadius="8"
                                    Click="OnOpenMediaManagerClick"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>

</Window>
