<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="StartTooler.Views.UploadProgressWindow"
        Width="360"
        Height="180"
        CanResize="False"
        ShowInTaskbar="False"
        SystemDecorations="BorderOnly"
        WindowStartupLocation="CenterOwner"
        Title="正在上传"
        Background="Transparent">
    <Border Padding="20"
            Background="{DynamicResource ProgressDialogBackgroundBrush}"
            CornerRadius="12"
            BorderBrush="{DynamicResource ProgressDialogBorderBrush}"
            BorderThickness="{DynamicResource ProgressDialogBorderThickness}">
        <StackPanel Spacing="10">
            <TextBlock x:Name="StatusText"
                       Text="正在上传文件..."
                       Foreground="{DynamicResource ProgressDialogTextBrush}"
                       FontSize="14"/>
            <ProgressBar x:Name="ProgressBar"
                         Height="8"
                         Minimum="0"
                         Maximum="100"
                         Value="0"
                         Foreground="{DynamicResource ProgressDialogBarBrush}"
                         Background="{DynamicResource ProgressDialogTrackBrush}"/>
            <TextBlock x:Name="FileProgressText"
                       Text=""
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       FontSize="11"
                       HorizontalAlignment="Center"/>
            <TextBlock x:Name="ProgressText"
                       Text="文件 0/0"
                       Foreground="{DynamicResource ProgressDialogTextBrush}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>
