<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StartTooler.ViewModels"
             xmlns:models="using:StartTooler.Models"
             xmlns:converters="using:StartTooler.Converters"
             x:Class="StartTooler.Views.GalleryView"
             x:DataType="vm:GalleryViewModel">

    <UserControl.Resources>
        <converters:GreaterThanOneConverter x:Key="GreaterThanOne"/>
        <converters:SyncStatusToColorConverter x:Key="SyncStatusToColor"/>
        <converters:SyncStatusToTooltipConverter x:Key="SyncStatusToTooltip"/>
    </UserControl.Resources>

    <Grid ColumnDefinitions="220,*">
        <!-- 时间轴 (TimelineRail) -->
        <Border Grid.Column="0" Background="{DynamicResource Bg.Outer}">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding TimelineEntries}" Margin="16,24">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="0"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:TimelineEntry">
                            <Button Classes="timeline-node"
                                    Command="{Binding $parent[UserControl].DataContext.SelectCommand}"
                                    CommandParameter="{Binding}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Grid ColumnDefinitions="40,*" RowDefinitions="Auto,Auto">
                                            <!-- 连接线 -->
                                            <Border Grid.Column="0" Grid.Row="0"
                                                    Width="1"
                                                    Background="{DynamicResource Bg.Divider}"
                                                    Margin="0,0,0,0"/>
                                            <!-- 圆点和日期 -->
                                            <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Vertical" HorizontalAlignment="Center">
                                                <!-- 圆点 -->
                                                <Ellipse Width="8" Height="8"
                                                         Fill="{DynamicResource Bg.Divider}"
                                                         HorizontalAlignment="Center"/>
                                                <!-- 连接线段 -->
                                                <Border Width="1" Height="40"
                                                        Background="{DynamicResource Bg.Divider}"
                                                        HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <!-- 日期文字 -->
                                            <TextBlock Grid.Column="1" Grid.Row="0"
                                                       Text="{Binding Date, StringFormat='{}{0:yyyy-MM-dd}'}"
                                                       FontFamily="{DynamicResource Font.Mono}"
                                                       FontSize="12"
                                                       FontWeight="500"
                                                       Foreground="{DynamicResource Text.Secondary}"
                                                       Margin="12,20,0,20"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- 照片网格区域 -->
        <Border Grid.Column="1" Background="{DynamicResource Bg.Surface}" CornerRadius="12,0,0,0">
            <Grid>
                <!-- 加载状态 - 骨架屏 -->
                <ScrollViewer IsVisible="{Binding IsLoading}">
                    <StackPanel Orientation="Horizontal" Margin="24">
                        <Border Width="160" Height="120" Background="{DynamicResource Bg.Divider}" CornerRadius="{DynamicResource Radius.Medium}" Margin="8" Opacity="0.5"/>
                        <Border Width="160" Height="120" Background="{DynamicResource Bg.Divider}" CornerRadius="{DynamicResource Radius.Medium}" Margin="8" Opacity="0.5"/>
                        <Border Width="160" Height="120" Background="{DynamicResource Bg.Divider}" CornerRadius="{DynamicResource Radius.Medium}" Margin="8" Opacity="0.5"/>
                        <Border Width="160" Height="120" Background="{DynamicResource Bg.Divider}" CornerRadius="{DynamicResource Radius.Medium}" Margin="8" Opacity="0.5"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- 空状态 -->
                <StackPanel IsVisible="{Binding IsEmpty}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="16">
                    <Path Data="{DynamicResource Icon.Constellation}"
                          Stretch="Uniform"
                          Width="64" Height="64"
                          Stroke="{DynamicResource Text.Disabled}"
                          StrokeThickness="1"
                          Fill="Transparent"
                          Opacity="0.4"
                          HorizontalAlignment="Center"/>
                    <TextBlock Text="该日期暂无照片"
                               FontSize="15"
                               FontWeight="600"
                               Foreground="{DynamicResource Text.Primary}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="去拍摄或导入新照片"
                               FontSize="13"
                               Foreground="{DynamicResource Text.Secondary}"
                               HorizontalAlignment="Center"/>
                    <Button Content="导入照片"
                            Classes="primary-button"
                            Command="{Binding ImportPhotosCommand}"
                            Height="36" Width="120"
                            Margin="0,8,0,0"/>
                </StackPanel>

                <!-- 错误状态 -->
                <StackPanel IsVisible="{Binding HasError}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="16">
                    <Path Data="{DynamicResource Icon.AlertTriangle}"
                          Stretch="Uniform"
                          Width="48" Height="48"
                          Fill="{DynamicResource State.Danger}"
                          HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding ErrorMessage}"
                               FontSize="13"
                               Foreground="{DynamicResource Text.Secondary}"
                               HorizontalAlignment="Center"/>
                    <Button Content="重试"
                            Classes="primary-button"
                            Command="{Binding RetryCommand}"
                            Height="36" Width="80"
                            Margin="0,8,0,0"/>
                </StackPanel>

                <!-- 照片网格 -->
                <ScrollViewer IsVisible="{Binding Photos.Count}">
                    <ItemsControl ItemsSource="{Binding Photos}" Margin="24">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" ItemWidth="160" ItemHeight="120"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:Photo">
                                <Button Classes="photo-tile"
                                        Margin="8"
                                        Command="{Binding $parent[UserControl].DataContext.SelectPhotoCommand}"
                                        CommandParameter="{Binding}">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="查看详情"
                                                      Command="{Binding $parent[UserControl].DataContext.OpenPhotoCommand}"
                                                      CommandParameter="{Binding}"/>
                                            <MenuItem Header="重新上传"
                                                      Command="{Binding $parent[UserControl].DataContext.ReuploadPhotoCommand}"
                                                      CommandParameter="{Binding}"/>
                                            <Separator/>
                                            <MenuItem Header="删除"
                                                      Command="{Binding $parent[UserControl].DataContext.DeletePhotoCommand}"
                                                      CommandParameter="{Binding}"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="PhotoBorder"
                                                    Width="160" Height="120"
                                                    Background="{DynamicResource Bg.Surface}"
                                                    CornerRadius="{DynamicResource Radius.Medium}"
                                                    ClipToBounds="True">
                                                <Grid>
                                                    <!-- 占位星座图标 -->
                                                    <Path Data="{DynamicResource Icon.Constellation}"
                                                          Stretch="Uniform"
                                                          Width="24" Height="24"
                                                          Stroke="{DynamicResource Text.Disabled}"
                                                          StrokeThickness="1"
                                                          Fill="Transparent"
                                                          Opacity="0.4"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>

                                                    <!-- 状态徽章 (StatusBadge) -->
                                                    <Panel HorizontalAlignment="Right"
                                                           VerticalAlignment="Top"
                                                           Margin="6">
                                                        <Path Width="16" Height="16"
                                                              Data="{DynamicResource Icon.Cloud}"
                                                              Fill="{Binding Status, Converter={StaticResource SyncStatusToColor}}"
                                                              Opacity="0.8"
                                                              ToolTip.Tip="{Binding Status, Converter={StaticResource SyncStatusToTooltip}}"/>
                                                    </Panel>

                                                    <!-- 数量徽章 -->
                                                    <Border IsVisible="{Binding GroupCount, Converter={StaticResource GreaterThanOne}}"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Bottom"
                                                            Margin="6"
                                                            Background="#CC1F2438"
                                                            CornerRadius="{DynamicResource Radius.Pill}"
                                                            Padding="8,2">
                                                        <TextBlock Text="{Binding GroupCount, StringFormat='{}{0}张'}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource Text.Primary}"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
