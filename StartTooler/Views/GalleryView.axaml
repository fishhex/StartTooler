<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StartTooler.ViewModels"
             xmlns:models="using:StartTooler.Models"
             xmlns:data="using:StartTooler.Data"
             xmlns:converters="using:StartTooler.Converters"
             x:Class="StartTooler.Views.GalleryView"
             x:DataType="vm:GalleryViewModel">

    <UserControl.Resources>
        <converters:SyncStatusToColorConverter x:Key="SyncStatusToColor"/>
        <converters:SyncStatusToTooltipConverter x:Key="SyncStatusToTooltip"/>
        <converters:BoolToAccentOrDividerConverter x:Key="BoolToAccentOrDivider"/>
        <converters:BoolToFontWeightConverter x:Key="BoolToFontWeight"/>
        <converters:BoolToAccentOrSecondaryConverter x:Key="BoolToAccentOrSecondary"/>
        <converters:MediaFileToStatusConverter x:Key="MediaFileToStatus"/>
        <converters:MediaFileToSyncVisibilityConverter x:Key="MediaFileToSyncVis"/>
        <converters:MediaTypeToVideoConverter x:Key="MediaTypeToVideo"/>
        <converters:FilePathToBitmapConverter x:Key="FilePathToBitmap"/>
        <converters:FilePathToVisibilityConverter x:Key="FilePathToVis"/>
        <converters:UploadStatusToVisibilityConverter x:Key="UploadStatusToVis"/>
        <!-- v0.6: AI 打标 3 个 Converter（photo tile 评分角标/标签条/TagError） -->
        <converters:ScoreToBrushConverter x:Key="ScoreToBrush"/>
        <converters:ScoreToDisplayConverter x:Key="ScoreToDisplay"/>
        <converters:TagsToShortTextConverter x:Key="TagsToShortText"/>
        <!-- v0.6.1: 标签分类 Converter（空标签 → 未分类） -->
        <converters:EmptyTagToUntitledConverter x:Key="EmptyTagToUntitled"/>
        <!-- v0.7: 质量标签 Converter（暖红调 quality 标签条截断/完整列表） -->
        <converters:QualityTagsToShortTextConverter x:Key="QualityTagsToShortText"/>
        <converters:QualityTagsToTooltipConverter x:Key="QualityTagsToTooltip"/>
    </UserControl.Resources>

    <!-- v2.3: 工具栏已移至 MainWindow 全局工具栏 -->
    <!-- 页面结构：时间轴(180) + 照片网格(*) -->
    <Grid ColumnDefinitions="180,*">
        <!-- v0.6.1: 左栏 — 顶部 TabControl + 下方 Date/Tag 双视图 -->
        <Border Grid.Column="0"
                Background="{DynamicResource Bg.Outer}"
                BorderBrush="{DynamicResource Bg.Divider}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- 顶部 TabControl（替代原 spec RadioButton）：0=时间 1=标签 -->
                <TabControl DockPanel.Dock="Top"
                            SelectedIndex="{Binding GroupModeIndex}"
                            Classes="group-tabs">
                    <TabItem Header="时间"/>
                    <TabItem Header="标签"/>
                </TabControl>

                <!-- 时间轴列表（GroupMode=Date 时显示） -->
                <ScrollViewer IsVisible="{Binding IsDateGroupMode}">
                    <ItemsControl ItemsSource="{Binding DateGroups}" Margin="16,0,16,24">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="0"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:TimelineEntry">
                                <Button Classes="timeline-node"
                                        Command="{Binding $parent[UserControl].((vm:GalleryViewModel)DataContext).SelectCommand}"
                                        CommandParameter="{Binding}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Canvas Width="150" Height="56">
                                                <!-- 圆点 -->
                                                <Ellipse Width="10" Height="10"
                                                         Fill="{Binding IsSelected, Converter={StaticResource BoolToAccentOrDivider}}"
                                                         Canvas.Left="8" Canvas.Top="23"/>
                                                <!-- 连接线段 (下方) -->
                                                <Border Width="2" Height="36"
                                                        Background="{DynamicResource Timeline.Line}"
                                                        Opacity="0.3"
                                                        Canvas.Left="12" Canvas.Top="33"/>
                                                <!-- 日期文字 -->
                                                <TextBlock Canvas.Left="32" Canvas.Top="20"
                                                           Text="{Binding Date, StringFormat='{}{0:yyyy-MM-dd}'}"
                                                           FontFamily="{DynamicResource Font.Mono}"
                                                           FontSize="13"
                                                           FontWeight="{Binding IsSelected, Converter={StaticResource BoolToFontWeight}}"
                                                           Foreground="{Binding IsSelected, Converter={StaticResource BoolToAccentOrSecondary}}"/>
                                            </Canvas>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- 标签列表（GroupMode=Tag 时显示） -->
                <ScrollViewer IsVisible="{Binding IsTagGroupMode}">
                    <ItemsControl ItemsSource="{Binding TagGroups}" Margin="16,0,16,24">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="0"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:TagGroupItem">
                                <Button Classes="tag-node"
                                        Command="{Binding $parent[UserControl].((vm:GalleryViewModel)DataContext).SelectTagCommand}"
                                        CommandParameter="{Binding}">
                                    <Grid>
                                        <TextBlock Text="{Binding Tag, Converter={StaticResource EmptyTagToUntitled}}"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   FontSize="13"/>
                                        <TextBlock Text="{Binding Count, StringFormat='{}{0} 张'}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource Text.Secondary}"/>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- 照片网格区域 -->
        <Border Grid.Column="1" Background="{DynamicResource Bg.Surface}">
            <Grid>
                <!-- 无项目目录空态 -->
                <StackPanel IsVisible="{Binding HasNoProject}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="16">
                    <Path Data="{DynamicResource Icon.Constellation}"
                          Stretch="Uniform"
                          Width="64" Height="64"
                          Stroke="{DynamicResource Text.Disabled}"
                          StrokeThickness="1"
                          Fill="Transparent"
                          Opacity="0.4"
                          HorizontalAlignment="Center"/>
                    <TextBlock Text="请先选择项目目录"
                               FontSize="15"
                               FontWeight="600"
                               Foreground="{DynamicResource Text.Primary}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="在设置中配置您的照片目录"
                               FontSize="13"
                               Foreground="{DynamicResource Text.Secondary}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- 无媒体空态 -->
                <StackPanel IsVisible="{Binding IsEmpty}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="16">
                    <Path Data="{DynamicResource Icon.Constellation}"
                          Stretch="Uniform"
                          Width="64" Height="64"
                          Stroke="{DynamicResource Text.Disabled}"
                          StrokeThickness="1"
                          Fill="Transparent"
                          Opacity="0.4"
                          HorizontalAlignment="Center"/>
                    <TextBlock Text="未发现媒体文件"
                               FontSize="15"
                               FontWeight="600"
                               Foreground="{DynamicResource Text.Primary}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="请先刷新扫描您的照片目录"
                               FontSize="13"
                               Foreground="{DynamicResource Text.Secondary}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- 加载骨架屏 -->
                <ScrollViewer IsVisible="{Binding IsLoadingDateGroups}">
                    <StackPanel Margin="24">
                        <TextBlock Text="加载中..."
                                   FontSize="13"
                                   Foreground="{DynamicResource Text.Secondary}"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- 错误状态 -->
                <StackPanel IsVisible="{Binding LoadErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="16">
                    <Path Data="{DynamicResource Icon.AlertTriangle}"
                          Stretch="Uniform"
                          Width="48" Height="48"
                          Fill="{DynamicResource State.Danger}"
                          HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding LoadErrorMessage}"
                               FontSize="13"
                               Foreground="{DynamicResource Text.Secondary}"
                               HorizontalAlignment="Center"/>
                    <Button Content="重试"
                            Classes="primary-button"
                            Command="{Binding ReloadCommand}"
                            Height="36" Width="80"
                            Margin="0,8,0,0"/>
                </StackPanel>

                <!-- 照片网格 -->
                <ScrollViewer IsVisible="{Binding !IsLoadingDateGroups}">
                    <ItemsControl ItemsSource="{Binding CurrentMediaFiles}" Margin="24">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" ItemWidth="160" ItemHeight="120"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="data:MediaFile">
                                <Button Classes="photo-tile"
                                        Margin="8"
                                        Command="{Binding $parent[ItemsControl].((vm:GalleryViewModel)DataContext).ToggleSelectionCommand}"
                                        CommandParameter="{Binding}"
                                        DoubleTapped="OnPhotoTileDoubleTapped">
                                    <!-- v0.6: 右键菜单 AI 打标 / v0.8: 加「删除」「释放本地空间」/ v0.8.1: 加「下载到本地」 -->
                                    <!-- 多选模式下右键不弹菜单（避免与多选冲突）：每个 MenuItem 单独控制 IsVisible -->
                                    <Button.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuItem Header="AI 打标"
                                                      Command="{Binding $parent[ItemsControl].((vm:GalleryViewModel)DataContext).TagSingleCommand}"
                                                      CommandParameter="{Binding}"
                                                      IsVisible="{Binding $parent[ItemsControl].((vm:GalleryViewModel)DataContext).IsMultiSelectMode, Converter={x:Static BoolConverters.Not}}"/>
                                            <MenuItem Header="删除"
                                                      Command="{Binding $parent[ItemsControl].((vm:GalleryViewModel)DataContext).DeleteSingleCommand}"
                                                      CommandParameter="{Binding}"
                                                      IsVisible="{Binding $parent[ItemsControl].((vm:GalleryViewModel)DataContext).IsMultiSelectMode, Converter={x:Static BoolConverters.Not}}"/>
                                            <!-- 「释放本地空间」仅云端已备份 + 本地存在的文件可见 + 非多选模式 -->
                                            <MenuItem Header="释放本地空间"
                                                      Command="{Binding $parent[ItemsControl].((vm:GalleryViewModel)DataContext).FreeUpSpaceCommand}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.IsVisible>
                                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                        <Binding Path="$parent[ItemsControl].((vm:GalleryViewModel)DataContext).IsMultiSelectMode" Converter="{x:Static BoolConverters.Not}"/>
                                                        <Binding Path="IsUploaded"/>
                                                        <Binding Path="LocalExists"/>
                                                    </MultiBinding>
                                                </MenuItem.IsVisible>
                                            </MenuItem>
                                            <!-- v0.8.1 新增：「下载到本地」仅云端已备份的文件可用 + 非多选模式 -->
                                            <!-- LocalExists 在命令内二次判断（spec §5.3） -->
                                            <MenuItem Header="下载到本地"
                                                      Command="{Binding $parent[ItemsControl].((vm:GalleryViewModel)DataContext).DownloadSingleCommand}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.IsVisible>
                                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                        <Binding Path="$parent[ItemsControl].((vm:GalleryViewModel)DataContext).IsMultiSelectMode" Converter="{x:Static BoolConverters.Not}"/>
                                                        <Binding Path="IsUploaded"/>
                                                    </MultiBinding>
                                                </MenuItem.IsVisible>
                                            </MenuItem>
                                        </MenuFlyout>
                                    </Button.ContextFlyout>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid>
                                                <!-- 选中时高亮边框: 浮在 PhotoBorder 外层, IsSelected=true 时显示 -->
                                                <Border x:Name="SelectionHighlight"
                                                        Width="160" Height="120"
                                                        CornerRadius="{DynamicResource Radius.Large}"
                                                        BorderBrush="{DynamicResource Accent.Stellar}"
                                                        BorderThickness="2"
                                                        IsVisible="{Binding IsSelected}"/>

                                                <!-- 照片卡片 -->
                                                <Border x:Name="PhotoBorder"
                                                        Width="160" Height="120"
                                                        Background="{DynamicResource Bg.SurfaceElevated}"
                                                        CornerRadius="{DynamicResource Radius.Large}"
                                                        ClipToBounds="True">

                                                    <Grid>
                                                        <!-- 缩略图（路径有效且文件存在才显示） -->
                                                        <Image Source="{Binding ThumbnailPath, Converter={StaticResource FilePathToBitmap}}"
                                                               Stretch="UniformToFill"
                                                               IsVisible="{Binding ThumbnailPath, Converter={StaticResource FilePathToVis}}"/>

                                                        <!-- 占位星座图标（路径空 或 文件不存在时显示） -->
                                                        <Path Data="{DynamicResource Icon.Constellation}"
                                                              Stretch="Uniform"
                                                              Width="48" Height="48"
                                                              Stroke="{DynamicResource Text.Disabled}"
                                                              StrokeThickness="1"
                                                              Fill="Transparent"
                                                              Opacity="0.4"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              IsVisible="{Binding ThumbnailPath, Converter={StaticResource FilePathToVis}, ConverterParameter=Invert}"/>

                                                        <!-- 视频徽章 (左上角) -->
                                                        <Border IsVisible="{Binding MediaType, Converter={StaticResource MediaTypeToVideo}}"
                                                                HorizontalAlignment="Left"
                                                                VerticalAlignment="Top"
                                                                Margin="6,10,10,6"
                                                                Width="22" Height="22"
                                                                Background="#CC0A0E1A"
                                                                CornerRadius="11">
                                                            <Path Data="{DynamicResource Icon.Play}"
                                                                  Stretch="Uniform"
                                                                  Width="12" Height="12"
                                                                  Fill="{DynamicResource State.Warning}"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                                        </Border>

                                                        <!--
                                                            右上角徽章分两组，互斥显示：
                                                            A. 瞬时进度态（Uploading/Failed/Paused）—— 由 UploadStatusToVis 绑定 UploadStatus
                                                            B. 持久同步态（UploadedAndLocal / UploadedButMissingLocal / NotUploaded）—— 由 MediaFileToSyncVis 派生

                                                            A 组在上传过程中优先显示；B 组在静止状态（已上传/未上传）显示。
                                                        -->

                                                        <!-- 同步态: 已上传且本地存在 (青蓝云 + ✓) -->
                                                        <Border IsVisible="{Binding ., Converter={StaticResource MediaFileToSyncVis}, ConverterParameter=UploadedAndLocal}"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Margin="6,10,10,6"
                                                                Width="24" Height="24"
                                                                Background="#CCFFFFFF"
                                                                CornerRadius="12">
                                                            <Grid>
                                                                <Path Data="M19.35 10.04C18.67 6.59 15.64 4 12 4C9.11 4 6.6 5.64 5.35 8.04C2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5c0-2.64-2.05-4.78-4.65-4.96z"
                                                                      Stretch="Uniform"
                                                                      Width="14" Height="14"
                                                                      Fill="#4DD0E1"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                                <Path Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"
                                                                      Stretch="Uniform"
                                                                      Width="10" Height="10"
                                                                      Fill="#FFFFFF"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"
                                                                      Margin="0,1,0,0"/>
                                                            </Grid>
                                                        </Border>

                                                        <!-- 同步态: 已上传但本地不存在 (橙色云 + ↓) -->
                                                        <Border IsVisible="{Binding ., Converter={StaticResource MediaFileToSyncVis}, ConverterParameter=UploadedButMissingLocal}"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Margin="6,10,10,6"
                                                                Width="24" Height="24"
                                                                Background="#CCFFFFFF"
                                                                CornerRadius="12">
                                                            <Grid>
                                                                <Path Data="M19.35 10.04C18.67 6.59 15.64 4 12 4C9.11 4 6.6 5.64 5.35 8.04C2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5c0-2.64-2.05-4.78-4.65-4.96z"
                                                                      Stretch="Uniform"
                                                                      Width="14" Height="14"
                                                                      Fill="#FFA726"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                                <Path Data="M20 12l-1.41-1.41L13 18.17V4h-2v14.17l-5.58-5.59L4 14l8 8 8-8z"
                                                                      Stretch="Uniform"
                                                                      Width="10" Height="10"
                                                                      Fill="#FFFFFF"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"
                                                                      Margin="0,2,0,0"/>
                                                            </Grid>
                                                        </Border>

                                                        <!-- 同步态: 未上传 (灰云 + 斜杠) -->
                                                        <Border IsVisible="{Binding ., Converter={StaticResource MediaFileToSyncVis}, ConverterParameter=NotUploaded}"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Margin="6,10,10,6"
                                                                Width="24" Height="24"
                                                                Background="#CCFFFFFF"
                                                                CornerRadius="12">
                                                            <Grid>
                                                                <Path Data="M19.35 10.04C18.67 6.59 15.64 4 12 4C9.11 4 6.6 5.64 5.35 8.04C2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5c0-2.64-2.05-4.78-4.65-4.96z"
                                                                      Stretch="Uniform"
                                                                      Width="14" Height="14"
                                                                      Fill="#4A5273"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                                <Path Data="M4 4 L20 20"
                                                                      Stroke="#FFFFFF"
                                                                      StrokeThickness="2.2"
                                                                      StrokeLineCap="Round"
                                                                      Width="14" Height="14"
                                                                      Stretch="Uniform"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>

                                                        <!-- Uploading: 半透明云 -->
                                                        <Border IsVisible="{Binding UploadStatus, Converter={StaticResource UploadStatusToVis}, ConverterParameter=Uploading}"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Margin="6,10,10,6"
                                                                Width="24" Height="24"
                                                                Background="#CCFFFFFF"
                                                                CornerRadius="12"
                                                                Opacity="0.85">
                                                            <Path Data="M19.35 10.04C18.67 6.59 15.64 4 12 4C9.11 4 6.6 5.64 5.35 8.04C2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5c0-2.64-2.05-4.78-4.65-4.96z"
                                                                  Stretch="Uniform"
                                                                  Width="14" Height="14"
                                                                  Fill="{DynamicResource Accent.Stellar}"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center">
                                                                <Path.RenderTransform>
                                                                    <RotateTransform Angle="0"/>
                                                                </Path.RenderTransform>
                                                            </Path>
                                                        </Border>

                                                        <!-- Failed: 红色云 + 感叹号 -->
                                                        <Border IsVisible="{Binding UploadStatus, Converter={StaticResource UploadStatusToVis}, ConverterParameter=Failed}"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Margin="6,10,10,6"
                                                                Width="24" Height="24"
                                                                Background="#CCFFFFFF"
                                                                CornerRadius="12">
                                                            <Grid>
                                                                <Path Data="M19.35 10.04C18.67 6.59 15.64 4 12 4C9.11 4 6.6 5.64 5.35 8.04C2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5c0-2.64-2.05-4.78-4.65-4.96z"
                                                                      Stretch="Uniform"
                                                                      Width="14" Height="14"
                                                                      Fill="{DynamicResource State.Danger}"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                                <TextBlock Text="!"
                                                                           FontSize="13"
                                                                           FontWeight="Bold"
                                                                           Foreground="#FFFFFF"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Margin="0,0,0,1"/>
                                                            </Grid>
                                                        </Border>

                                                        <!-- Paused: 黄色云 -->
                                                        <Border IsVisible="{Binding UploadStatus, Converter={StaticResource UploadStatusToVis}, ConverterParameter=Paused}"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Margin="6,10,10,6"
                                                                Width="24" Height="24"
                                                                Background="#CCFFFFFF"
                                                                CornerRadius="12">
                                                            <Path Data="M19.35 10.04C18.67 6.59 15.64 4 12 4C9.11 4 6.6 5.64 5.35 8.04C2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5c0-2.64-2.05-4.78-4.65-4.96z"
                                                                  Stretch="Uniform"
                                                                  Width="14" Height="14"
                                                                  Fill="{DynamicResource State.Warning}"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                                        </Border>

                                                        <!-- v0.6: 评分角标 (左下) -->
                                                        <Border IsVisible="{Binding HasScore}"
                                                                HorizontalAlignment="Left"
                                                                VerticalAlignment="Bottom"
                                                                Margin="6,6,10,6"
                                                                Padding="6,2"
                                                                Background="{Binding Score, Converter={StaticResource ScoreToBrush}}"
                                                                CornerRadius="8">
                                                            <TextBlock Text="{Binding Score, Converter={StaticResource ScoreToDisplay}}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#FFFFFF"
                                                                       VerticalAlignment="Center"/>
                                                        </Border>

                                                        <!-- v0.6: 标签小角标条 (底部居中, hover tooltip 看完整) -->
                                                        <Border IsVisible="{Binding HasTags}"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Bottom"
                                                                Margin="0,0,0,6"
                                                                Padding="6,2"
                                                                MaxWidth="140"
                                                                Background="#CC0A0E1A"
                                                                CornerRadius="8"
                                                                ToolTip.Tip="{Binding Tags, Converter={StaticResource TagsToShortText}, ConverterParameter=Full}">
                                                            <TextBlock Text="{Binding Tags, Converter={StaticResource TagsToShortText}}"
                                                                       FontSize="10"
                                                                       Foreground="#E6FFFFFF"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       MaxLines="1"/>
                                                        </Border>

                                                        <!-- v0.7: 质量评价标签条 (底部居中, subject 标签条上方; 暖红底暖橙字, 视觉区分) -->
                                                        <Border IsVisible="{Binding HasQualityTags}"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Bottom"
                                                                Margin="0,0,0,24"
                                                                Padding="6,2"
                                                                MaxWidth="140"
                                                                Background="#CC3A1F1A"
                                                                CornerRadius="8"
                                                                ToolTip.Tip="{Binding QualityTags, Converter={StaticResource QualityTagsToTooltip}}">
                                                            <TextBlock Text="{Binding QualityTags, Converter={StaticResource QualityTagsToShortText}}"
                                                                       FontSize="10"
                                                                       Foreground="#FFCC8888"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       MaxLines="1"/>
                                                        </Border>

                                                        <!-- v0.6: 打标失败徽章 (右下, hover tooltip 看错误原因) -->
                                                        <Border IsVisible="{Binding TagError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Bottom"
                                                                Margin="6,6,10,6"
                                                                Width="20" Height="20"
                                                                Background="#CCFFFFFF"
                                                                CornerRadius="10"
                                                                ToolTip.Tip="{Binding TagError}">
                                                            <Path Data="{DynamicResource Icon.AlertTriangle}"
                                                                  Width="12" Height="12"
                                                                  Fill="{DynamicResource State.Danger}"
                                                                  Stretch="Uniform"/>
                                                        </Border>

                                                        <!-- 选中时遮罩: 半透明蓝色叠加 -->
                                                        <Border IsVisible="{Binding IsSelected}"
                                                                Background="#334FC3F7"
                                                                IsHitTestVisible="False"/>

                                                        <!-- 多选模式复选框 (垂直水平居中) -->
                                                        <Panel HorizontalAlignment="Center"
                                                               VerticalAlignment="Center">
                                                            <!-- 未选中的空心圆 (多选模式但未选中) -->
                                                            <Border Width="28" Height="28"
                                                                    Background="#AA000000"
                                                                    BorderBrush="#E6FFFFFF"
                                                                    BorderThickness="2"
                                                                    CornerRadius="14"
                                                                    IsVisible="{Binding $parent[ItemsControl].((vm:GalleryViewModel)DataContext).IsMultiSelectMode}"/>

                                                            <!-- 已选中的对勾 (多选模式 + 已选中) -->
                                                            <Border Width="28" Height="28"
                                                                    Background="{DynamicResource Accent.Stellar}"
                                                                    BorderBrush="#FFFFFF"
                                                                    BorderThickness="2"
                                                                    CornerRadius="14"
                                                                    IsVisible="{Binding IsSelected}">
                                                                <Path Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"
                                                                      Stretch="Uniform"
                                                                      Width="18" Height="18"
                                                                      Fill="#0A0E1A"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                            </Border>
                                                        </Panel>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
