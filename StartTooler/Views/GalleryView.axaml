<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StartTooler.ViewModels"
             xmlns:models="using:StartTooler.Models"
             xmlns:data="using:StartTooler.Data"
             xmlns:converters="using:StartTooler.Converters"
             x:Class="StartTooler.Views.GalleryView"
             x:DataType="vm:GalleryViewModel">

    <UserControl.Resources>
        <converters:SyncStatusToColorConverter x:Key="SyncStatusToColor"/>
        <converters:SyncStatusToTooltipConverter x:Key="SyncStatusToTooltip"/>
        <converters:BoolToAccentOrDividerConverter x:Key="BoolToAccentOrDivider"/>
        <converters:BoolToFontWeightConverter x:Key="BoolToFontWeight"/>
        <converters:BoolToAccentOrSecondaryConverter x:Key="BoolToAccentOrSecondary"/>
        <converters:MediaFileToStatusConverter x:Key="MediaFileToStatus"/>
        <converters:MediaTypeToVideoConverter x:Key="MediaTypeToVideo"/>
        <converters:FilePathToBitmapConverter x:Key="FilePathToBitmap"/>
        <converters:IsFileSelectedConverter x:Key="IsFileSelected"/>
        <converters:FileSelectionStateConverter x:Key="FileSelectionState"/>
    </UserControl.Resources>

    <!-- v2.3: 工具栏已移至 MainWindow 全局工具栏 -->
    <!-- 页面结构：时间轴(180) + 照片网格(*) -->
    <Grid ColumnDefinitions="180,*">
        <!-- 时间轴 -->
        <Border Grid.Column="0"
                Background="{DynamicResource Bg.Outer}"
                BorderBrush="{DynamicResource Bg.Divider}"
                BorderThickness="0,0,1,0">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding DateGroups}" Margin="16,24">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="0"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:TimelineEntry">
                            <Button Classes="timeline-node"
                                    Command="{Binding $parent[UserControl].DataContext.SelectCommand}"
                                    CommandParameter="{Binding}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Canvas Width="150" Height="56">
                                            <!-- 圆点 -->
                                            <Ellipse Width="10" Height="10"
                                                     Fill="{Binding IsSelected, Converter={StaticResource BoolToAccentOrDivider}}"
                                                     Canvas.Left="8" Canvas.Top="23"/>
                                            <!-- 连接线段 (下方) -->
                                            <Border Width="2" Height="36"
                                                    Background="{DynamicResource Timeline.Line}"
                                                    Opacity="0.3"
                                                    Canvas.Left="12" Canvas.Top="33"/>
                                            <!-- 日期文字 -->
                                            <TextBlock Canvas.Left="32" Canvas.Top="20"
                                                       Text="{Binding Date, StringFormat='{}{0:yyyy-MM-dd}'}"
                                                       FontFamily="{DynamicResource Font.Mono}"
                                                       FontSize="13"
                                                       FontWeight="{Binding IsSelected, Converter={StaticResource BoolToFontWeight}}"
                                                       Foreground="{Binding IsSelected, Converter={StaticResource BoolToAccentOrSecondary}}"/>
                                        </Canvas>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- 照片网格区域 -->
        <Border Grid.Column="1" Background="{DynamicResource Bg.Surface}">
            <Grid>
                <!-- 无项目目录空态 -->
                <StackPanel IsVisible="{Binding HasNoProject}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="16">
                    <Path Data="{DynamicResource Icon.Constellation}"
                          Stretch="Uniform"
                          Width="64" Height="64"
                          Stroke="{DynamicResource Text.Disabled}"
                          StrokeThickness="1"
                          Fill="Transparent"
                          Opacity="0.4"
                          HorizontalAlignment="Center"/>
                    <TextBlock Text="请先选择项目目录"
                               FontSize="15"
                               FontWeight="600"
                               Foreground="{DynamicResource Text.Primary}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="在设置中配置您的照片目录"
                               FontSize="13"
                               Foreground="{DynamicResource Text.Secondary}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- 无媒体空态 -->
                <StackPanel IsVisible="{Binding IsEmpty}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="16">
                    <Path Data="{DynamicResource Icon.Constellation}"
                          Stretch="Uniform"
                          Width="64" Height="64"
                          Stroke="{DynamicResource Text.Disabled}"
                          StrokeThickness="1"
                          Fill="Transparent"
                          Opacity="0.4"
                          HorizontalAlignment="Center"/>
                    <TextBlock Text="未发现媒体文件"
                               FontSize="15"
                               FontWeight="600"
                               Foreground="{DynamicResource Text.Primary}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="请先刷新扫描您的照片目录"
                               FontSize="13"
                               Foreground="{DynamicResource Text.Secondary}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- 加载骨架屏 -->
                <ScrollViewer IsVisible="{Binding IsLoadingDateGroups}">
                    <StackPanel Margin="24">
                        <TextBlock Text="加载中..."
                                   FontSize="13"
                                   Foreground="{DynamicResource Text.Secondary}"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- 错误状态 -->
                <StackPanel IsVisible="{Binding LoadErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="16">
                    <Path Data="{DynamicResource Icon.AlertTriangle}"
                          Stretch="Uniform"
                          Width="48" Height="48"
                          Fill="{DynamicResource State.Danger}"
                          HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding LoadErrorMessage}"
                               FontSize="13"
                               Foreground="{DynamicResource Text.Secondary}"
                               HorizontalAlignment="Center"/>
                    <Button Content="重试"
                            Classes="primary-button"
                            Command="{Binding ReloadCommand}"
                            Height="36" Width="80"
                            Margin="0,8,0,0"/>
                </StackPanel>

                <!-- 照片网格 -->
                <ScrollViewer IsVisible="{Binding !IsLoadingDateGroups}">
                    <ItemsControl ItemsSource="{Binding CurrentMediaFiles}" Margin="24">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" ItemWidth="160" ItemHeight="120"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="data:MediaFile">
                                <Button Classes="photo-tile"
                                        Margin="8"
                                        Command="{Binding $parent[ItemsControl].((vm:GalleryViewModel)DataContext).ToggleSelectionCommand}"
                                        CommandParameter="{Binding}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid>
                                                <!-- 不可见的状态源 Border (承载 MultiBinding 结果) -->
                                                <Border x:Name="SelectionStateSource"
                                                        IsVisible="False">
                                                    <Border.Tag>
                                                        <MultiBinding Converter="{x:Static converters:FileSelectionStateConverter.Instance}">
                                                            <Binding/>
                                                            <Binding Path="$parent[ItemsControl].((vm:GalleryViewModel)DataContext).SelectedFiles"/>
                                                            <Binding Path="$parent[ItemsControl].((vm:GalleryViewModel)DataContext).IsMultiSelectMode"/>
                                                        </MultiBinding>
                                                    </Border.Tag>
                                                </Border>

                                                <!-- 照片卡片 -->
                                                <Border x:Name="PhotoBorder"
                                                        Width="160" Height="120"
                                                        Background="{DynamicResource Bg.SurfaceElevated}"
                                                        CornerRadius="{DynamicResource Radius.Large}"
                                                        ClipToBounds="True"
                                                        BorderBrush="{DynamicResource Accent.Stellar}"
                                                        BorderThickness="{Binding #SelectionStateSource.Tag, Converter={x:Static converters:SelectionBorderThicknessConverter.Instance}}">

                                                    <Grid>
                                                        <!-- 缩略图 -->
                                                        <Image Source="{Binding ThumbnailPath, Converter={StaticResource FilePathToBitmap}}"
                                                               Stretch="UniformToFill"
                                                               IsVisible="{Binding ThumbnailPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                                                        <!-- 占位星座图标 -->
                                                        <Path Data="{DynamicResource Icon.Constellation}"
                                                              Stretch="Uniform"
                                                              Width="48" Height="48"
                                                              Stroke="{DynamicResource Text.Disabled}"
                                                              StrokeThickness="1"
                                                              Fill="Transparent"
                                                              Opacity="0.4"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              IsVisible="{Binding ThumbnailPath, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>

                                                        <!-- 视频徽章 (右上角) -->
                                                        <Border IsVisible="{Binding MediaType, Converter={StaticResource MediaTypeToVideo}}"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Margin="6"
                                                                Width="22" Height="22"
                                                                Background="#CC0A0E1A"
                                                                CornerRadius="11">
                                                            <Path Data="{DynamicResource Icon.Play}"
                                                                  Stretch="Uniform"
                                                                  Width="12" Height="12"
                                                                  Fill="{DynamicResource State.Warning}"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                                        </Border>

                                                        <!-- 同步状态云朵图标 (右上角, 视频徽章下方) -->
                                                        <Border IsVisible="{Binding IsUploaded}"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Margin="6,32,6,6"
                                                                Width="24" Height="24"
                                                                Background="#CCFFFFFF"
                                                                CornerRadius="12">
                                                            <Path Data="M19.35 10.04C18.67 6.59 15.64 4 12 4C9.11 4 6.6 5.64 5.35 8.04C2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5c0-2.64-2.05-4.78-4.65-4.96z"
                                                                  Stretch="Uniform"
                                                                  Width="14" Height="14"
                                                                  Fill="{DynamicResource Accent.Stellar}"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                                        </Border>

                                                        <!-- v2.3 选中时遮罩: 半透明蓝色叠加, 加强选中反馈 -->
                                                        <Border IsVisible="{Binding #SelectionStateSource.Tag, Converter={x:Static converters:IsCheckedConverter.Instance}}"
                                                                Background="#334FC3F7"
                                                                IsHitTestVisible="False"/>

                                                        <!-- v2.3.2: 多选模式复选框 (垂直水平居中) -->
                                                        <Panel HorizontalAlignment="Center"
                                                               VerticalAlignment="Center">
                                                            <!-- 未选中的空心圆 (多选模式但未选中) -->
                                                            <Border Width="28" Height="28"
                                                                    Background="#AA000000"
                                                                    BorderBrush="#E6FFFFFF"
                                                                    BorderThickness="2"
                                                                    CornerRadius="14"
                                                                    IsVisible="{Binding #SelectionStateSource.Tag, Converter={x:Static converters:IsUncheckedConverter.Instance}}"/>

                                                            <!-- 已选中的对勾 (多选模式 + 已选中) -->
                                                            <Border Width="28" Height="28"
                                                                    Background="{DynamicResource Accent.Stellar}"
                                                                    BorderBrush="#FFFFFF"
                                                                    BorderThickness="2"
                                                                    CornerRadius="14"
                                                                    IsVisible="{Binding #SelectionStateSource.Tag, Converter={x:Static converters:IsCheckedConverter.Instance}}">
                                                                <Path Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"
                                                                      Stretch="Uniform"
                                                                      Width="18" Height="18"
                                                                      Fill="#0A0E1A"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                            </Border>
                                                        </Panel>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
