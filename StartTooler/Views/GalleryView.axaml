<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StartTooler.ViewModels"
             xmlns:models="using:StartTooler.Models"
             xmlns:data="using:StartTooler.Data"
             xmlns:converters="using:StartTooler.Converters"
             x:Class="StartTooler.Views.GalleryView"
             x:DataType="vm:GalleryViewModel">

    <UserControl.Resources>
        <!-- v0.6.1: 标签分类 Converter（空标签 → 未分类） -->
        <converters:EmptyTagToUntitledConverter x:Key="EmptyTagToUntitled"/>
        <!-- v0.6: AI 打标 3 个 Converter（photo tile 评分角标/标签条） -->
        <converters:ScoreToBrushConverter x:Key="ScoreToBrush"/>
        <converters:ScoreToDisplayConverter x:Key="ScoreToDisplay"/>
        <converters:TagsToShortTextConverter x:Key="TagsToShortText"/>
        <!-- v0.7: 质量标签 Converter -->
        <converters:QualityTagsToShortTextConverter x:Key="QualityTagsToShortText"/>
        <converters:QualityTagsToTooltipConverter x:Key="QualityTagsToTooltip"/>
        <!-- v0.11: 同步状态徽章 4 合一 Converter（spec §5.1） -->
        <converters:SyncStatusToSingleBadgeVis x:Key="SyncBadgeToVis"/>
        <converters:SyncStatusToSingleBadgeColor x:Key="SyncBadgeToColor"/>
        <converters:SyncStatusToSingleBadgeIcon x:Key="SyncBadgeToIcon"/>
        <converters:SyncStatusToSingleBadgeTooltip x:Key="SyncBadgeToTooltip"/>
        <!-- 通用：文件 → 缩略图 / 视频 / 占位 -->
        <converters:FilePathToBitmapConverter x:Key="FilePathToBitmap"/>
        <converters:FilePathToVisibilityConverter x:Key="FilePathToVis"/>
        <converters:MediaTypeToVideoConverter x:Key="MediaTypeToVideo"/>
        <!-- 通用：选中态视觉（标签列表 spec §15.4） -->
        <converters:BoolToAccentOrSecondaryConverter x:Key="BoolToAccentOrSecondary"/>
        <converters:BoolToFontWeightConverter x:Key="BoolToFontWeight"/>
    </UserControl.Resources>

    <!-- v2.3: 工具栏已移至 MainWindow 全局工具栏 -->
    <!-- 页面结构：时间轴(180) + 照片网格(*) -->
    <Grid ColumnDefinitions="180,*">
        <!-- v0.6.1: 左栏 — 顶部 TabControl + 下方 Date/Tag 双视图 -->
        <Border Grid.Column="0"
                Background="{DynamicResource Bg.Outer}"
                BorderBrush="{DynamicResource Bg.Divider}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- 顶部 TabControl（替代原 spec RadioButton）：0=时间 1=标签 -->
                <TabControl DockPanel.Dock="Top"
                            SelectedIndex="{Binding GroupModeIndex}"
                            Classes="group-tabs">
                    <TabItem Header="时间"/>
                    <TabItem Header="标签"/>
                </TabControl>

                <!-- 时间轴列表（GroupMode=Date 时显示） -->
                <ScrollViewer IsVisible="{Binding IsDateGroupMode}">
                    <ItemsControl ItemsSource="{Binding DateGroups}" Margin="16,0,16,24">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="0"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:TimelineEntry">
                                <Button Classes="timeline-node"
                                        Command="{Binding $parent[UserControl].((vm:GalleryViewModel)DataContext).SelectCommand}"
                                        CommandParameter="{Binding}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <!-- v0.11: 高度 48→56 容纳日期+数量双行（spec §15.3） -->
                                            <Canvas Width="150" Height="56">
                                                <!-- 圆点 -->
                                                <Ellipse Width="10" Height="10"
                                                         Fill="{Binding IsSelected, Converter={StaticResource BoolToAccentOrSecondary}}"
                                                         Canvas.Left="8" Canvas.Top="22"/>
                                                <!-- 连接线段 (下方) -->
                                                <Border Width="2" Height="32"
                                                        Background="{DynamicResource Timeline.Line}"
                                                        Opacity="0.3"
                                                        Canvas.Left="12" Canvas.Top="32"/>
                                                <!-- 日期文字 + 数量（双行） -->
                                                <StackPanel Canvas.Left="32" Canvas.Top="14" Spacing="2">
                                                    <TextBlock Text="{Binding Date, StringFormat='{}{0:yyyy-MM-dd}'}"
                                                               FontFamily="{DynamicResource Font.Mono}" FontSize="13"
                                                               FontWeight="{Binding IsSelected, Converter={StaticResource BoolToFontWeight}}"
                                                               Foreground="{Binding IsSelected, Converter={StaticResource BoolToAccentOrSecondary}}"/>
                                                    <TextBlock Text="{Binding PhotoCount, StringFormat='{}{0} 张'}"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource Text.Tertiary}"/>
                                                </StackPanel>
                                            </Canvas>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- 标签列表（GroupMode=Tag 时显示） -->
                <ScrollViewer IsVisible="{Binding IsTagGroupMode}">
                    <ItemsControl ItemsSource="{Binding TagGroups}" Margin="16,0,16,24">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="0"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:TagGroupItem">
                                <Button Classes="tag-node"
                                        Command="{Binding $parent[UserControl].((vm:GalleryViewModel)DataContext).SelectTagCommand}"
                                        CommandParameter="{Binding}">
                                    <Grid>
                                        <!-- v0.11: 选中态文字变色 / 加粗（spec §15.4） -->
                                        <TextBlock Text="{Binding Tag, Converter={StaticResource EmptyTagToUntitled}}"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   FontSize="13"
                                                   FontWeight="{Binding IsSelected, Converter={StaticResource BoolToFontWeight}}"
                                                   Foreground="{Binding IsSelected, Converter={StaticResource BoolToAccentOrSecondary}}"/>
                                        <TextBlock Text="{Binding Count, StringFormat='{}{0} 张'}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"
                                                   Foreground="{Binding IsSelected, Converter={StaticResource BoolToAccentOrSecondary}}"/>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- 照片网格区域 -->
        <Border Grid.Column="1" Background="{DynamicResource Bg.Surface}">
            <Grid>
                <!-- 无项目目录空态 -->
                <StackPanel IsVisible="{Binding HasNoProject}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="16">
                    <Path Data="{DynamicResource Icon.Constellation}"
                          Stretch="Uniform"
                          Width="64" Height="64"
                          Stroke="{DynamicResource Card.EmptyStateStroke}"
                          StrokeThickness="1"
                          Fill="Transparent"
                          Opacity="0.4"
                          HorizontalAlignment="Center"/>
                    <TextBlock Text="请先选择项目目录"
                               FontSize="15"
                               FontWeight="600"
                               Foreground="{DynamicResource Text.Primary}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="在设置中配置您的照片目录"
                               FontSize="13"
                               Foreground="{DynamicResource Text.Secondary}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- 无媒体空态 -->
                <StackPanel IsVisible="{Binding IsEmpty}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="16">
                    <Path Data="{DynamicResource Icon.Constellation}"
                          Stretch="Uniform"
                          Width="64" Height="64"
                          Stroke="{DynamicResource Card.EmptyStateStroke}"
                          StrokeThickness="1"
                          Fill="Transparent"
                          Opacity="0.4"
                          HorizontalAlignment="Center"/>
                    <TextBlock Text="未发现媒体文件"
                               FontSize="15"
                               FontWeight="600"
                               Foreground="{DynamicResource Text.Primary}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="请先刷新扫描您的照片目录"
                               FontSize="13"
                               Foreground="{DynamicResource Text.Secondary}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!--
                  v0.11: 骨架屏替代 "加载中..." 纯文字（spec §9）。
                  标题行 placeholder + 8 张 tile placeholder + 第二个标题 + 5 张 tile placeholder。
                -->
                <ScrollViewer IsVisible="{Binding IsLoadingDateGroups}">
                    <StackPanel Margin="24" Spacing="16">
                        <Border Classes="skeleton" Width="180" Height="16" CornerRadius="4" />
                        <WrapPanel>
                            <Border Classes="skeleton pulse" Width="160" Height="120" CornerRadius="8" Margin="4" />
                            <Border Classes="skeleton pulse" Width="160" Height="120" CornerRadius="8" Margin="4" />
                            <Border Classes="skeleton pulse" Width="160" Height="120" CornerRadius="8" Margin="4" />
                            <Border Classes="skeleton pulse" Width="160" Height="120" CornerRadius="8" Margin="4" />
                            <Border Classes="skeleton pulse" Width="160" Height="120" CornerRadius="8" Margin="4" />
                            <Border Classes="skeleton pulse" Width="160" Height="120" CornerRadius="8" Margin="4" />
                            <Border Classes="skeleton pulse" Width="160" Height="120" CornerRadius="8" Margin="4" />
                            <Border Classes="skeleton pulse" Width="160" Height="120" CornerRadius="8" Margin="4" />
                        </WrapPanel>
                        <Border Classes="skeleton" Width="140" Height="16" CornerRadius="4" Margin="0,12,0,0" />
                        <WrapPanel>
                            <Border Classes="skeleton pulse" Width="160" Height="120" CornerRadius="8" Margin="4" />
                            <Border Classes="skeleton pulse" Width="160" Height="120" CornerRadius="8" Margin="4" />
                            <Border Classes="skeleton pulse" Width="160" Height="120" CornerRadius="8" Margin="4" />
                            <Border Classes="skeleton pulse" Width="160" Height="120" CornerRadius="8" Margin="4" />
                            <Border Classes="skeleton pulse" Width="160" Height="120" CornerRadius="8" Margin="4" />
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- 错误状态 -->
                <StackPanel IsVisible="{Binding LoadErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="16">
                    <Path Data="{DynamicResource Icon.AlertTriangle}"
                          Stretch="Uniform"
                          Width="48" Height="48"
                          Fill="{DynamicResource State.Danger}"
                          HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding LoadErrorMessage}"
                               FontSize="13"
                               Foreground="{DynamicResource Text.Secondary}"
                               HorizontalAlignment="Center"/>
                    <Button Content="重试"
                            Classes="primary-button"
                            Command="{Binding ReloadCommand}"
                            Height="36" Width="80"
                            Margin="0,8,0,0"/>
                </StackPanel>

                <!-- 照片网格 -->
                <ScrollViewer x:Name="PhotoScrollViewer" IsVisible="{Binding !IsLoadingDateGroups}">
                    <Grid>
                        <ItemsControl ItemsSource="{Binding CurrentMediaFiles}" Margin="24">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" ItemWidth="160" ItemHeight="120"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="data:MediaFile">
                                    <Button Classes="photo-tile"
                                            Margin="8"
                                            Command="{Binding $parent[ItemsControl].((vm:GalleryViewModel)DataContext).ToggleSelectionCommand}"
                                            CommandParameter="{Binding}"
                                            DoubleTapped="OnPhotoTileDoubleTapped"
                                            PointerPressed="OnPhotoTilePointerPressed">
                                        <!-- 详见 GalleryView.axaml.cs：右键菜单 code-behind 构建 -->
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <!--
                                                  v0.11: PointerEntered/Exited 在 code-behind 订阅（spec §5.3）。
                                                  原因：编译 binding 模式下 Avalonia XAML 在 Button/Grid 上对继承自
                                                  InputElement 的 PointerEntered/Exited 解析失败（AVLN3000）。
                                                  改在 View 的 OnPhotoScrollViewerPointerMoved 统一处理：
                                                  维护 _hoveredFiles 集合，OnApplyTemplate 时给 ScrollViewer
                                                  AddHandler(PointerEnteredEvent) / AddHandler(PointerExitedEvent)。
                                                -->
                                                <Grid>
                                                    <!--
                                                      v0.11: 选中时高亮边框 + 键盘焦点边框 (spec §7)。
                                                      SelectionHighlight 显示在 PhotoBorder 上层，KeyboardFocusBorder 更外层；
                                                      两个状态可同时存在（多选+键盘焦点）。
                                                    -->
                                                    <Border Width="160" Height="120"
                                                            CornerRadius="{DynamicResource Radius.Large}"
                                                            BorderBrush="{DynamicResource Accent.Stellar}"
                                                            BorderThickness="2"
                                                            IsVisible="{Binding IsKeyboardFocused}"/>
                                                    <Border x:Name="SelectionHighlight"
                                                            Width="160" Height="120"
                                                            CornerRadius="{DynamicResource Radius.Large}"
                                                            BorderBrush="{DynamicResource Accent.Stellar}"
                                                            BorderThickness="2"
                                                            IsVisible="{Binding IsSelected}"/>

                                                    <!-- 照片卡片 -->
                                                    <Border x:Name="PhotoBorder"
                                                            Width="160" Height="120"
                                                            Background="{DynamicResource Bg.SurfaceElevated}"
                                                            CornerRadius="{DynamicResource Radius.Large}"
                                                            ClipToBounds="True">

                                                        <Grid>
                                                            <!-- 缩略图 -->
                                                            <Image Source="{Binding ThumbnailPath, Converter={StaticResource FilePathToBitmap}}"
                                                                   Stretch="UniformToFill"
                                                                   IsVisible="{Binding ThumbnailPath, Converter={StaticResource FilePathToVis}}"/>

                                                            <!-- 占位星座图标 -->
                                                            <Path Data="{DynamicResource Icon.Constellation}"
                                                                  Stretch="Uniform"
                                                                  Width="48" Height="48"
                                                                  Stroke="{DynamicResource Card.EmptyStateStroke}"
                                                                  StrokeThickness="1"
                                                                  Fill="Transparent"
                                                                  Opacity="0.4"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  IsVisible="{Binding ThumbnailPath, Converter={StaticResource FilePathToVis}, ConverterParameter=Invert}"/>

                                                            <!-- 视频徽章 (左上角) -->
                                                            <Border IsVisible="{Binding MediaType, Converter={StaticResource MediaTypeToVideo}}"
                                                                    HorizontalAlignment="Left"
                                                                    VerticalAlignment="Top"
                                                                    Margin="6,10,10,6"
                                                                    Width="22" Height="22"
                                                                    Background="{DynamicResource Overlay.Dark}"
                                                                    CornerRadius="11">
                                                                <Path Data="{DynamicResource Icon.Play}"
                                                                      Stretch="Uniform"
                                                                      Width="12" Height="12"
                                                                      Fill="{DynamicResource State.Warning}"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                            </Border>

                                                            <!--
                                                              v0.11: 同步状态徽章 6→1 合并（spec §5.1）。
                                                              单 Border 由 4 个 Converter 各负责一个属性：
                                                                - Background ← SyncBadgeToColor
                                                                - IsVisible   ← SyncBadgeToVis
                                                                - ToolTip.Tip ← SyncBadgeToTooltip
                                                                - PathIcon.Data ← SyncBadgeToIcon
                                                            -->
                                                            <Border IsVisible="{Binding ., Converter={StaticResource SyncBadgeToVis}}"
                                                                    HorizontalAlignment="Right"
                                                                    VerticalAlignment="Top"
                                                                    Margin="6,10,10,6"
                                                                    Width="24" Height="24"
                                                                    Background="{Binding ., Converter={StaticResource SyncBadgeToColor}}"
                                                                    CornerRadius="12"
                                                                    ToolTip.Tip="{Binding ., Converter={StaticResource SyncBadgeToTooltip}}">
                                                                <PathIcon Data="{Binding ., Converter={StaticResource SyncBadgeToIcon}}"
                                                                          Width="14" Height="14"
                                                                          Foreground="White"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                            </Border>

                                                            <!--
                                                              v0.11: 评分 + 内容标签 合并为单条底部信息栏（spec §5.2）。
                                                              替代原「左下评分角标 + 底部居中标签条」两行冗余。
                                                              暖色背景适配白字；评分 + 标签横排展示。
                                                            -->
                                                            <Border IsVisible="{Binding HasScore}"
                                                                    HorizontalAlignment="Stretch"
                                                                    VerticalAlignment="Bottom"
                                                                    Margin="0"
                                                                    Padding="6,3"
                                                                    Background="{DynamicResource Card.FooterBg}">
                                                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                                    <Border IsVisible="{Binding HasScore}"
                                                                            Background="{Binding Score, Converter={StaticResource ScoreToBrush}}"
                                                                            CornerRadius="6"
                                                                            Padding="4,1">
                                                                        <TextBlock Text="{Binding Score, Converter={StaticResource ScoreToDisplay}}"
                                                                                   FontSize="10" FontWeight="Bold"
                                                                                   Foreground="White"
                                                                                   VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <TextBlock Text="{Binding Tags, Converter={StaticResource TagsToShortText}}"
                                                                               FontSize="10"
                                                                               Foreground="{DynamicResource Card.FooterText}"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               MaxLines="1"
                                                                               MaxWidth="90"
                                                                               VerticalAlignment="Center"
                                                                               ToolTip.Tip="{Binding Tags, Converter={StaticResource TagsToShortText}, ConverterParameter=Full}"/>
                                                                </StackPanel>
                                                            </Border>

                                                            <!--
                                                              v0.11: 质量标签仅 hover 显示（spec §5.3）。
                                                              IsHovered 由 View 的 PointerEnter/Leave 维护，IsVisible 绑定。
                                                              没 hover 时质量条完全不占位。
                                                            -->
                                                            <Border IsVisible="{Binding IsHovered}"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Bottom"
                                                                    Margin="0,0,0,28"
                                                                    Padding="6,2"
                                                                    MaxWidth="140"
                                                                    Background="{DynamicResource Tag.QualityBg}"
                                                                    CornerRadius="8"
                                                                    ToolTip.Tip="{Binding QualityTags, Converter={StaticResource QualityTagsToTooltip}}">
                                                                <TextBlock Text="{Binding QualityTags, Converter={StaticResource QualityTagsToShortText}}"
                                                                           FontSize="10"
                                                                           Foreground="{DynamicResource Tag.QualityFg}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           MaxLines="1"/>
                                                            </Border>

                                                            <!-- 打标失败徽章 (右下, hover tooltip 看错误原因) -->
                                                            <Border IsVisible="{Binding TagError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                                    HorizontalAlignment="Right"
                                                                    VerticalAlignment="Bottom"
                                                                    Margin="6,6,10,6"
                                                                    Width="20" Height="20"
                                                                    Background="{DynamicResource Overlay.Light}"
                                                                    CornerRadius="10"
                                                                    ToolTip.Tip="{Binding TagError}">
                                                                <Path Data="{DynamicResource Icon.AlertTriangle}"
                                                                      Width="12" Height="12"
                                                                      Fill="{DynamicResource State.Danger}"
                                                                      Stretch="Uniform"/>
                                                            </Border>

                                                            <!-- 选中时遮罩: 半透明蓝色叠加 -->
                                                            <Border IsVisible="{Binding IsSelected}"
                                                                    Background="{DynamicResource Overlay.Selection}"
                                                                    IsHitTestVisible="False"/>

                                                            <!-- 多选模式复选框 (垂直水平居中) -->
                                                            <Panel HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center">
                                                                <!-- 未选中的空心圆 -->
                                                                <Border Width="28" Height="28"
                                                                        Background="{DynamicResource Select.CheckBg}"
                                                                        BorderBrush="{DynamicResource Select.CheckBorder}"
                                                                        BorderThickness="2"
                                                                        CornerRadius="14"
                                                                        IsVisible="{Binding $parent[ItemsControl].((vm:GalleryViewModel)DataContext).IsMultiSelectMode}"/>

                                                                <!-- 已选中的对勾 -->
                                                                <Border Width="28" Height="28"
                                                                        Background="{DynamicResource Select.CheckFilled}"
                                                                        BorderBrush="{DynamicResource Select.CheckFilledBorder}"
                                                                        BorderThickness="2"
                                                                        CornerRadius="14"
                                                                        IsVisible="{Binding IsSelected}">
                                                                    <Path Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"
                                                                          Stretch="Uniform"
                                                                          Width="18" Height="18"
                                                                          Fill="{DynamicResource Select.CheckTickFg}"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                                </Border>
                                                            </Panel>
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!--
                          v0.11: 拖拽矩形框选层（spec §8）。IsHitTestVisible=False 让 Canvas 不拦截 Pointer 事件
                          → 原始 photo tile 仍能接收 PointerPressed/Moved/Released；
                          marquee Border 是 code-behind 动态添加到 Canvas 的。
                        -->
                        <Canvas x:Name="SelectionCanvas" IsHitTestVisible="False" />
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
