<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="StartTooler.Views.ScanProgressWindow"
        Width="320"
        Height="160"
        CanResize="False"
        ShowInTaskbar="False"
        SystemDecorations="BorderOnly"
        WindowStartupLocation="CenterOwner"
        Title="正在扫描"
        Background="Transparent">
    <Border Padding="20"
            Background="{DynamicResource ProgressDialogBackgroundBrush}"
            CornerRadius="12"
            BorderBrush="{DynamicResource ProgressDialogBorderBrush}"
            BorderThickness="{DynamicResource ProgressDialogBorderThickness}">
        <StackPanel Spacing="12">
            <TextBlock x:Name="StatusText"
                       Text="正在扫描文件..."
                       Foreground="{DynamicResource ProgressDialogTextBrush}"
                       FontSize="14"/>
            <ProgressBar x:Name="ProgressBar"
                         Height="12"
                         IsIndeterminate="True"
                         Foreground="{DynamicResource ProgressDialogBarBrush}"
                         Background="{DynamicResource ProgressDialogTrackBrush}"/>
        </StackPanel>
    </Border>
</Window>
