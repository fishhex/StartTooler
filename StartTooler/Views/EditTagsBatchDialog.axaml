<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:StartTooler.ViewModels"
        xmlns:controls="using:StartTooler.Controls"
        mc:Ignorable="d" d:DesignWidth="520" d:DesignHeight="720"
        x:Class="StartTooler.Views.EditTagsBatchDialog"
        x:DataType="vm:EditTagsBatchDialogViewModel"
        Title="{Binding Title}"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="BorderOnly"
        CanResize="False"
        SizeToContent="WidthAndHeight"
        MinWidth="480" MinHeight="600"
        MaxHeight="800"
        Background="{DynamicResource Bg.Outer}">

    <!--
      批量编辑标签模态弹窗（v0.11 重写）。

      布局：
        - 顶部标题 + 已有标签上下文
        - 操作区 1：清除所有标签
        - 操作区 2：添加标签（chip 编辑器 + 标签建议云 + 应用按钮）
        - 操作区 3：删除标签（chip 编辑器 + 应用按钮）
        - 进度条（IsApplying 时显示）
        - 底部取消按钮
    -->

    <Border Padding="20" Background="{DynamicResource Bg.Surface}"
            BorderBrush="{DynamicResource Bg.Divider}" BorderThickness="1" CornerRadius="8">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" RowSpacing="12">

            <!-- ============ 标题 + 已有标签上下文 ============ -->
            <StackPanel Grid.Row="0" Spacing="6">
                <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource Text.Primary}" />

                <!-- 已有标签上下文 -->
                <Border Background="{DynamicResource Bg.SurfaceElevated}"
                        CornerRadius="4" Padding="8,6"
                        IsVisible="{Binding HasExistingTags}">
                    <StackPanel Spacing="2">
                        <TextBlock FontSize="11" Foreground="{DynamicResource Text.Tertiary}"
                                   TextWrapping="Wrap">
                            <Run Text="已选文件标签：" />
                            <Run Text="{Binding ExistingTagsText}" FontWeight="SemiBold"
                                 Foreground="{DynamicResource Text.Secondary}" />
                        </TextBlock>
                        <TextBlock FontSize="11" Foreground="{DynamicResource Text.Tertiary}"
                                   TextWrapping="Wrap">
                            <Run Text="共同标签：" />
                            <Run Text="{Binding CommonTagsText}" FontWeight="SemiBold"
                                 Foreground="{DynamicResource Accent.Stellar}" />
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ============ 操作区 1：清除所有标签 ============ -->
            <Border Grid.Row="1"
                    Background="{DynamicResource Bg.SurfaceElevated}"
                    BorderBrush="{DynamicResource Bg.Divider}" BorderThickness="1"
                    CornerRadius="6" Padding="14">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                    <StackPanel Grid.Row="0" Spacing="4">
                        <TextBlock Text="清除所有标签" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Text.Primary}" />
                        <TextBlock FontSize="11" Foreground="{DynamicResource Text.Tertiary}"
                                   TextWrapping="Wrap">
                            <Run Text="将此" />
                            <Run Text="{Binding FileCount, Mode=OneWay}" FontWeight="SemiBold" />
                            <Run Text="个文件的所有标签一次性清空（不影响 AI 评分与质量标签）。" />
                        </TextBlock>
                    </StackPanel>

                    <Button Grid.Row="1"
                            IsVisible="{Binding ShouldShowClearInitialButton}"
                            Classes="danger-button"
                            HorizontalAlignment="Left"
                            Padding="14,6"
                            Command="{Binding RequestClearTagsCommand}"
                            IsEnabled="{Binding CanClearAllTags}">
                        <TextBlock Text="清除所有标签" FontWeight="SemiBold" />
                    </Button>

                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal" Spacing="8"
                                IsVisible="{Binding ShouldShowClearConfirmRow}">
                        <Button Classes="danger-button"
                                Padding="14,6"
                                Command="{Binding ConfirmClearTagsCommand}"
                                IsEnabled="{Binding CanClearAllTags}">
                            <TextBlock Text="确认清除" FontWeight="SemiBold" />
                        </Button>
                        <Button Classes="secondary-button"
                                Padding="14,6"
                                Command="{Binding CancelClearTagsCommand}">
                            <TextBlock Text="取消" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============ 操作区 2：添加标签 ============ -->
            <Border Grid.Row="2"
                    Background="{DynamicResource Bg.SurfaceElevated}"
                    BorderBrush="{DynamicResource Bg.Divider}" BorderThickness="1"
                    CornerRadius="6" Padding="14">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="10">
                    <StackPanel Grid.Row="0" Spacing="4">
                        <TextBlock Text="添加标签" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Text.Primary}" />
                        <TextBlock FontSize="11" Foreground="{DynamicResource Text.Tertiary}"
                                   TextWrapping="Wrap">
                            <Run Text="将下方 chip 追加到这" />
                            <Run Text="{Binding FileCount, Mode=OneWay}" FontWeight="SemiBold" />
                            <Run Text="个文件中（保留已有标签，去重合并）。" />
                        </TextBlock>
                    </StackPanel>

                    <!-- chip 编辑器 -->
                    <controls:TagChipEditor Grid.Row="1" DataContext="{Binding}" />

                    <!-- 输入提示 -->
                    <TextBlock Grid.Row="2" Text="提示：按 Enter 添加标签，点击 chip 删除"
                               FontSize="10" Foreground="{DynamicResource Text.Disabled}" />

                    <!-- 标签建议云 -->
                    <Border Grid.Row="3"
                            IsVisible="{Binding HasSuggestedTags}"
                            Background="{DynamicResource Bg.Surface}" CornerRadius="4" Padding="8,6">
                        <StackPanel Spacing="6">
                            <TextBlock Text="项目标签（点击快速添加）" FontSize="10"
                                       Foreground="{DynamicResource Text.Tertiary}" />
                            <ItemsControl ItemsSource="{Binding SuggestedTags}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Classes="suggestion-chip"
                                                Command="{Binding $parent[Window].DataContext.AddSuggestedTagCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="点击添加">
                                            <TextBlock Text="{Binding}" FontSize="11"
                                                       Foreground="{DynamicResource Text.Secondary}" />
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ============ 操作区 3：删除标签 ============ -->
            <Border Grid.Row="3"
                    Background="{DynamicResource Bg.SurfaceElevated}"
                    BorderBrush="{DynamicResource Bg.Divider}" BorderThickness="1"
                    CornerRadius="6" Padding="14">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                    <StackPanel Grid.Row="0" Spacing="4">
                        <TextBlock Text="删除标签" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Text.Primary}" />
                        <TextBlock FontSize="11" Foreground="{DynamicResource Text.Tertiary}"
                                   TextWrapping="Wrap">
                            <Run Text="点击已有标签右侧的" />
                            <Run Text="×" FontWeight="SemiBold" Foreground="{DynamicResource State.Danger}" />
                            <Run Text="，从这" />
                            <Run Text="{Binding FileCount, Mode=OneWay}" FontWeight="SemiBold" />
                            <Run Text="个文件中移除该标签。" />
                        </TextBlock>
                    </StackPanel>

                    <!-- 已有标签 chip 列表，每个带 x 按钮 -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding RemovableTags}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Classes="removable-chip"
                                        Margin="0,0,6,4">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="{Binding}" FontSize="12"
                                                   Foreground="{DynamicResource Text.Secondary}"
                                                   VerticalAlignment="Center" />
                                        <Button Classes="removable-x"
                                                Command="{Binding $parent[Window].DataContext.RemoveSpecificTagCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="删除此标签">
                                            <TextBlock Text="×" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource State.Danger}" />
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- ============ 进度条 + 底部按钮 ============ -->
            <StackPanel Grid.Row="4" Spacing="8" VerticalAlignment="Bottom">
                <!-- 进度条 -->
                <Border IsVisible="{Binding IsApplying}"
                        Background="{DynamicResource Bg.SurfaceElevated}"
                        CornerRadius="4" Padding="10,8">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="6">
                        <TextBlock Grid.Row="0" Text="{Binding ApplyProgressText}"
                                   FontSize="11" Foreground="{DynamicResource Text.Secondary}" />
                        <ProgressBar Grid.Row="1"
                                     Minimum="0"
                                     Maximum="{Binding ApplyProgressTotal}"
                                     Value="{Binding ApplyProgressCurrent}"
                                     Height="4"
                                     Foreground="{DynamicResource Accent.Stellar}"
                                     Background="{DynamicResource Bg.Divider}" />
                    </Grid>
                </Border>

                <!-- 底部按钮 -->
                <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
                    <!-- 添加标签「应用到 N 个文件」按钮 -->
                    <Button Grid.Column="0"
                            Classes="primary-button"
                            Command="{Binding ApplyAddTagsCommand}"
                            IsEnabled="{Binding CanApplyAddTags}"
                            Padding="14,8">
                        <TextBlock>
                            <Run Text="应用到" />
                            <Run Text="{Binding AddAffectedCount}" FontWeight="SemiBold" />
                            <Run Text="个文件" />
                        </TextBlock>
                    </Button>
                    <Border Grid.Column="1" />
                    <Button Grid.Column="2" Content="取消" Click="OnCancelClick"
                            Classes="secondary-button" Padding="14,8" />
                </Grid>
            </StackPanel>
        </Grid>
    </Border>

    <!-- 建议标签 chip 样式 -->
    <Window.Styles>
        <Style Selector="Button.suggestion-chip">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource Bg.Divider}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Margin" Value="0,2,4,2" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.suggestion-chip:pointerover">
            <Setter Property="Background" Value="{DynamicResource Accent.Stellar.Subtle}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Accent.Stellar}" />
        </Style>
        <Style Selector="Border.removable-chip">
            <Setter Property="Background" Value="{DynamicResource Bg.Surface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Bg.Divider}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="6,2" />
        </Style>
        <Style Selector="Button.removable-x">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="2,0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.removable-x:pointerover">
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="{DynamicResource State.Danger}" Opacity="0.12" />
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Styles>
</Window>