<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StartTooler.ViewModels"
             x:Class="StartTooler.Views.UploadServerView"
             x:DataType="vm:UploadServerViewModel">

    <ScrollViewer>
        <StackPanel Margin="40,24" Spacing="24">

            <!-- 标题 -->
            <TextBlock Text="上传服务"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource Text.Primary}"/>

            <!-- 服务控制 + 二维码（合并 card，运行时二维码在右侧） -->
            <Border Background="{DynamicResource Bg.Surface}"
                    CornerRadius="8"
                    Padding="24">
                <Grid ColumnDefinitions="*,Auto">
                    <!-- 左：服务控制 -->
                    <StackPanel Grid.Column="0" Spacing="16">
                        <TextBlock Text="局域网上传"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Text.Primary}"/>

                        <TextBlock Text="在其他设备上打开以下链接，上传图片或视频。文件会自动按日期归档到当前项目目录。"
                                   FontSize="12"
                                   Foreground="{DynamicResource Text.Secondary}"
                                   TextWrapping="Wrap"/>

                        <!-- 端口配置 -->
                        <Grid ColumnDefinitions="100,*">
                            <TextBlock Grid.Column="0"
                                       Text="端口"
                                       FontSize="13"
                                       Foreground="{DynamicResource Text.Primary}"
                                       VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                                <NumericUpDown Value="{Binding Port}"
                                               Minimum="1024"
                                               Maximum="65535"
                                               Width="120"
                                               IsEnabled="{Binding !IsRunning}"
                                               VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <!-- 启动按钮 -->
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button Content="启动服务"
                                    Classes="primary-button"
                                    Command="{Binding StartServerCommand}"
                                    IsVisible="{Binding !IsRunning}"/>
                            <Button Content="停止服务"
                                    Classes="secondary-button"
                                    Command="{Binding StopServerCommand}"
                                    IsVisible="{Binding IsRunning}"/>
                        </StackPanel>

                        <!-- 状态消息 -->
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="12"
                                   Foreground="{DynamicResource State.Success}"
                                   IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                        <!-- 错误消息 -->
                        <TextBlock Text="{Binding ErrorMessage}"
                                   FontSize="12"
                                   Foreground="{DynamicResource State.Error}"
                                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>

                    <!-- 右：二维码（运行时显示） -->
                    <StackPanel Grid.Column="1"
                                Spacing="12"
                                Margin="24,0,0,0"
                                VerticalAlignment="Top"
                                IsVisible="{Binding IsRunning}">
                        <TextBlock Text="扫码上传"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Text.Primary}"
                                   HorizontalAlignment="Center"/>

                        <Image Source="{Binding QrCodeImage}"
                               Width="180"
                               Height="180"
                               HorizontalAlignment="Center"/>

                        <TextBlock Text="{Binding UploadUrl}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Text.Secondary}"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   MaxWidth="220"/>

                        <TextBlock Text="{Binding RecentUploadMessage}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Accent.Stellar}"
                                   HorizontalAlignment="Center"
                                   IsVisible="{Binding RecentUploadMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 公网代理设置（折叠在下方，默认折叠） -->
            <Expander Header="公网代理设置"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
                <Border Padding="20,12,20,20">
                    <StackPanel Spacing="10">

                        <TextBlock Text="通过 SSH 在 VPS 上部署代理，手机扫码通过公网中转到本机 StartTooler。"
                                   FontSize="12"
                                   Foreground="{DynamicResource Text.Secondary}"
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="⚠ 请先在「设置」里选择项目目录"
                                   FontSize="12"
                                   Foreground="{DynamicResource State.Error}"
                                   IsVisible="{Binding PublicRelayViewModel.IsProjectPathSet, Converter={x:Static BoolConverters.Not}}"/>

                        <!-- 认证方式 -->
                        <Grid ColumnDefinitions="100,*">
                            <TextBlock Grid.Column="0" Text="认证方式" FontSize="13" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1"
                                      SelectedIndex="{Binding PublicRelayViewModel.AuthMethodIndex}"
                                      Width="200"
                                      HorizontalAlignment="Left">
                                <ComboBoxItem Content="密码"/>
                                <ComboBoxItem Content="SSH Key"/>
                            </ComboBox>
                        </Grid>

                        <!-- SSH Host -->
                        <Grid ColumnDefinitions="100,*">
                            <TextBlock Grid.Column="0" Text="SSH Host" FontSize="13" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding PublicRelayViewModel.SshHost}" Watermark="例如 vps.example.com"/>
                        </Grid>

                        <!-- SSH Port -->
                        <Grid ColumnDefinitions="100,*">
                            <TextBlock Grid.Column="0" Text="SSH Port" FontSize="13" VerticalAlignment="Center"/>
                            <NumericUpDown Grid.Column="1" Value="{Binding PublicRelayViewModel.SshPort}"
                                           Minimum="1" Maximum="65535" Width="120" HorizontalAlignment="Left"/>
                        </Grid>

                        <!-- User -->
                        <Grid ColumnDefinitions="100,*">
                            <TextBlock Grid.Column="0" Text="User" FontSize="13" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding PublicRelayViewModel.SshUser}" Watermark="SSH 用户名"/>
                        </Grid>

                        <!-- Password -->
                        <Grid ColumnDefinitions="100,*" IsVisible="{Binding PublicRelayViewModel.ShowPasswordFields}">
                            <TextBlock Grid.Column="0" Text="Password" FontSize="13" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding PublicRelayViewModel.SshPassword}" PasswordChar="•"/>
                        </Grid>

                        <!-- SSH Key -->
                        <Grid ColumnDefinitions="100,*" IsVisible="{Binding PublicRelayViewModel.ShowKeyFields}">
                            <TextBlock Grid.Column="0" Text="Key Path" FontSize="13" VerticalAlignment="Center"/>
                            <DockPanel Grid.Column="1">
                                <Button DockPanel.Dock="Right"
                                        Content="浏览..."
                                        Command="{Binding PublicRelayViewModel.BrowseKeyCommand}"
                                        Margin="8,0,0,0"/>
                                <TextBox Text="{Binding PublicRelayViewModel.SshKeyPath}" Watermark="例如 ~/.ssh/id_rsa"/>
                            </DockPanel>
                        </Grid>

                        <!-- Remote Path -->
                        <Grid ColumnDefinitions="100,*">
                            <TextBlock Grid.Column="0" Text="Remote Path" FontSize="13" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding PublicRelayViewModel.SshRemotePath}" Watermark="~/starttooler"/>
                        </Grid>

                        <!-- HTTP Port -->
                        <Grid ColumnDefinitions="100,*">
                            <TextBlock Grid.Column="0" Text="HTTP Port" FontSize="13" VerticalAlignment="Center"/>
                            <NumericUpDown Grid.Column="1" Value="{Binding PublicRelayViewModel.HttpPort}"
                                           Minimum="1" Maximum="65535" Width="120" HorizontalAlignment="Left"/>
                        </Grid>

                        <!-- TCP Port -->
                        <Grid ColumnDefinitions="100,*">
                            <TextBlock Grid.Column="0" Text="TCP Port" FontSize="13" VerticalAlignment="Center"/>
                            <NumericUpDown Grid.Column="1" Value="{Binding PublicRelayViewModel.TcpPort}"
                                           Minimum="1" Maximum="65535" Width="120" HorizontalAlignment="Left"/>
                        </Grid>

                        <!-- Public Host -->
                        <Grid ColumnDefinitions="100,*">
                            <TextBlock Grid.Column="0" Text="公网 Host" FontSize="13" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding PublicRelayViewModel.PublicHost}" Watermark="留空用 SSH Host"/>
                        </Grid>

                        <!-- 按钮 -->
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                            <Button Content="保存" Classes="secondary-button"
                                    Command="{Binding PublicRelayViewModel.SaveCommand}"
                                    IsEnabled="{Binding PublicRelayViewModel.IsDirty}"/>
                            <Button Content="部署" Classes="secondary-button"
                                    Command="{Binding PublicRelayViewModel.DeployCommand}"/>
                            <Button Content="启动" Classes="primary-button"
                                    Command="{Binding PublicRelayViewModel.StartCommand}"
                                    IsEnabled="{Binding PublicRelayViewModel.IsProjectPathSet}"/>
                            <Button Content="停止" Classes="secondary-button"
                                    Command="{Binding PublicRelayViewModel.StopCommand}"/>
                        </StackPanel>

                        <!-- 状态 / 错误 / 日志 -->
                        <Grid ColumnDefinitions="100,*" Margin="0,8,0,0">
                            <TextBlock Grid.Column="0" Text="状态" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding PublicRelayViewModel.RelayStateText}"
                                       FontSize="13" Foreground="{DynamicResource Text.Secondary}" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid ColumnDefinitions="100,*">
                            <TextBlock Grid.Column="0" Text="错误" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding PublicRelayViewModel.LastError}"
                                       FontSize="12" Foreground="{DynamicResource State.Error}"
                                       TextWrapping="Wrap" VerticalAlignment="Center"
                                       IsVisible="{Binding PublicRelayViewModel.LastError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        </Grid>

                        <Grid ColumnDefinitions="100,*">
                            <TextBlock Grid.Column="0" Text="日志" FontSize="13" VerticalAlignment="Top" Margin="0,6,0,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding PublicRelayViewModel.LastLog}"
                                       FontSize="12" Foreground="{DynamicResource Text.Secondary}"
                                       TextWrapping="Wrap" Margin="0,6,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</UserControl>