<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StartTooler.ViewModels"
             x:Class="StartTooler.Views.UploadServerView"
             x:DataType="vm:UploadServerViewModel">

    <ScrollViewer>
        <StackPanel Margin="40,24" Spacing="24">

            <!--
              v0.11 spec/17: 双卡片布局。LAN 上传（左）+ 扫码上传（右）等宽并排；
              间距 Space.5 (24)，外层 Grid MinWidth 防窄窗口挤压。
            -->
            <Grid ColumnDefinitions="*,*" MinWidth="720">
                <!-- 左：LAN 上传卡片 -->
                <Border Grid.Column="0"
                        Background="{DynamicResource Bg.Surface}"
                        CornerRadius="{DynamicResource Radius.Large}"
                        Padding="24"
                        Margin="0,0,12,0">
                    <StackPanel Spacing="16">
                        <!-- 头部：图标 + 标题 -->
                        <Grid ColumnDefinitions="Auto,*">
                            <Border Grid.Column="0"
                                    Width="32" Height="32"
                                    CornerRadius="{DynamicResource Radius.Medium}"
                                    Background="{DynamicResource Bg.SurfaceElevated}"
                                    VerticalAlignment="Center">
                                <PathIcon Data="{StaticResource Icon.Upload}"
                                          Width="16" Height="16"
                                          Foreground="{DynamicResource Accent.Stellar}"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="局域网上传"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource Text.Primary}"/>
                                <TextBlock Text="同一网络下点对点直传"
                                           FontSize="12"
                                           Foreground="{DynamicResource Text.Secondary}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="在同一网络下打开链接，上传图片或视频。文件会自动按日期归档到当前项目目录。"
                                   FontSize="12"
                                   Foreground="{DynamicResource Text.Secondary}"
                                   TextWrapping="Wrap"/>

                        <!-- 端口冲突时的建议端口（spec §3.3） -->
                        <StackPanel Spacing="6"
                                    IsVisible="{Binding IsPortConflict}">
                            <TextBlock Text="{Binding ErrorMessage}"
                                       FontSize="12"
                                       Foreground="{DynamicResource State.Danger}"
                                       TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="建议端口："
                                           FontSize="12"
                                           Foreground="{DynamicResource Text.Secondary}"
                                           VerticalAlignment="Center"/>
                                <ItemsControl ItemsSource="{Binding SuggestedPorts}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="6"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding}"
                                                    Command="{Binding $parent[UserControl].DataContext.UseRandomPortCommand}"
                                                    CommandParameter="{Binding}"
                                                    Padding="10,4"
                                                    Classes="secondary-button"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>

                        <!-- PORT + URL 横向入口条（图片布局） -->
                        <Grid ColumnDefinitions="Auto,*">
                            <!-- 左侧：PORT 面板 -->
                            <Border Grid.Column="0"
                                    Background="{DynamicResource Bg.SurfaceElevated}"
                                    CornerRadius="{DynamicResource Radius.Medium}"
                                    Padding="16,12"
                                    VerticalAlignment="Center">
                                <Grid ColumnDefinitions="Auto,Auto">
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="PORT"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource Text.Tertiary}"/>
                                        <TextBlock Text="{Binding Port}"
                                                   FontSize="28"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource Text.Primary}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                        <Button Classes="toolbar-button"
                                                Padding="6,2"
                                                Command="{Binding IncreasePortCommand}"
                                                IsEnabled="{Binding !IsRunning}"
                                                ToolTip.Tip="增加端口">
                                            <TextBlock Text="▲" FontSize="8" Foreground="{DynamicResource Text.Secondary}"/>
                                        </Button>
                                        <Button Classes="toolbar-button"
                                                Padding="6,2"
                                                Command="{Binding DecreasePortCommand}"
                                                IsEnabled="{Binding !IsRunning}"
                                                ToolTip.Tip="减少端口">
                                            <TextBlock Text="▼" FontSize="8" Foreground="{DynamicResource Text.Secondary}"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- 右侧：URL 访问条 -->
                            <StackPanel Grid.Column="1"
                                        Margin="16,0,0,0"
                                        VerticalAlignment="Center"
                                        IsVisible="{Binding IsRunning}">
                                <TextBlock Text="用手机扫码立即访问"
                                           FontSize="12"
                                           Foreground="{DynamicResource Text.Secondary}"
                                           Margin="0,0,0,6"/>
                                <Border Background="{DynamicResource Bg.SurfaceElevated}"
                                        CornerRadius="{DynamicResource Radius.Pill}"
                                        Padding="4">
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                        <Button Grid.Column="0"
                                                Content="复制"
                                                Command="{Binding CopyUrlCommand}"
                                                Classes="toolbar-button"
                                                Padding="12,6"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="{DynamicResource Accent.Stellar}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DisplayUploadUrl}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource Accent.Stellar}"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip.Tip="{Binding DisplayUploadUrl}"/>
                                        <Button Grid.Column="2"
                                                Command="{Binding PreviousAddressCommand}"
                                                Classes="toolbar-button"
                                                Padding="8,6"
                                                IsEnabled="{Binding CanShiftAddress}"
                                                ToolTip.Tip="上一个地址">
                                            <PathIcon Data="{StaticResource Icon.ChevronLeft}"
                                                      Width="12" Height="12"
                                                      Foreground="{DynamicResource Text.Secondary}"/>
                                        </Button>
                                        <Button Grid.Column="3"
                                                Command="{Binding NextAddressCommand}"
                                                Classes="toolbar-button"
                                                Padding="8,6"
                                                IsEnabled="{Binding CanShiftAddress}"
                                                ToolTip.Tip="下一个地址">
                                            <PathIcon Data="{StaticResource Icon.ChevronRight}"
                                                      Width="12" Height="12"
                                                      Foreground="{DynamicResource Text.Secondary}"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- 服务控制 / 状态 -->
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button Content="启动服务"
                                    Classes="primary-button"
                                    Command="{Binding StartServerCommand}"
                                    IsVisible="{Binding !IsRunning}"/>
                            <Button Command="{Binding StopServerCommand}"
                                    Classes="danger-button"
                                    IsVisible="{Binding IsRunning}"
                                    ToolTip.Tip="停止服务">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="6" Height="6"
                                             VerticalAlignment="Center"
                                             Fill="{DynamicResource State.Danger}"/>
                                    <TextBlock Text="停止服务" FontSize="13"/>
                                </StackPanel>
                            </Button>
                            <TextBlock Text="{Binding StatusMessage}"
                                       FontSize="12"
                                       Foreground="{DynamicResource State.Success}"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding ShowSuccessStatus}"/>
                        </StackPanel>

                        <!-- 上传历史（spec §3.1：最多 50 条 ScrollViewer 滚动；空时不显示） -->
                        <StackPanel Spacing="6"
                                    IsVisible="{Binding HasUploadHistory}">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="最近上传"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource Text.Primary}"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1"
                                        Content="清除"
                                        Classes="toolbar-button"
                                        FontSize="11"
                                        Command="{Binding ClearUploadHistoryCommand}"/>
                            </Grid>
                            <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding UploadHistory}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                                                <TextBlock Text="{Binding FileName}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource Text.Primary}"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="220"/>
                                                <TextBlock Text="{Binding FileSize, StringFormat={}{0:N0} B}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource Text.Secondary}"/>
                                                <TextBlock Text="✓"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource State.Success}"
                                                           IsVisible="{Binding IsSuccess}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>

                        <TextBlock Text="修改端口后自动重启"
                                   FontSize="11"
                                   Foreground="{DynamicResource Text.Tertiary}"/>
                    </StackPanel>
                </Border>

                <!-- 右：扫码上传卡片 -->
                <Border Grid.Column="1"
                        Background="{DynamicResource Bg.Surface}"
                        CornerRadius="{DynamicResource Radius.Large}"
                        Padding="24"
                        Margin="12,0,0,0">
                    <StackPanel Spacing="16">
                        <!-- 头部：标题 + 副标题 -->
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="扫码上传"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Text.Primary}"/>
                            <TextBlock Text="QR · 扫码即可访问上传页"
                                       FontSize="12"
                                       Foreground="{DynamicResource Text.Secondary}"/>
                        </StackPanel>

                        <!-- 公网中转小标记（保留 v0.10 行为） -->
                        <Border Background="{DynamicResource Accent.Stellar}"
                                CornerRadius="3"
                                Padding="6,2"
                                HorizontalAlignment="Center"
                                IsVisible="{Binding IsPublicMode}">
                            <TextBlock Text="公网中转中"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="White"/>
                        </Border>

                        <!-- 二维码区域：运行后显示 Image，未运行时显示占位 -->
                        <Border Width="180" Height="180"
                                HorizontalAlignment="Center"
                                Background="{DynamicResource Bg.SurfaceElevated}"
                                CornerRadius="{DynamicResource Radius.Medium}">
                            <Grid>
                                <Image Source="{Binding QrCodeImage}"
                                       Width="180" Height="180"
                                       IsVisible="{Binding IsRunning}"/>
                                <TextBlock Text="启动服务后生成二维码"
                                           FontSize="12"
                                           Foreground="{DynamicResource Text.Secondary}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="140"
                                           TextAlignment="Center"
                                           IsVisible="{Binding !IsRunning}"/>
                            </Grid>
                        </Border>

                        <TextBlock Text="用手机扫码立即访问"
                                   FontSize="12"
                                   Foreground="{DynamicResource Text.Secondary}"
                                   HorizontalAlignment="Center"/>

                        <!-- 最近一次上传的瞬时提示 -->
                        <TextBlock Text="{Binding RecentUploadMessage}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Accent.Stellar}"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="220"
                                   IsVisible="{Binding RecentUploadMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                        <TextBlock Text="二维码永久有效，同一局域网下均可访问"
                                   FontSize="11"
                                   Foreground="{DynamicResource Text.Tertiary}"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!--
              v0.11 spec/18: 公网代理设置 Expander 重设计。
              展开后为左右两栏表单，全部颜色/间距/圆角走 design tokens。
            -->
            <Expander Header="公网代理设置"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch"
                      Background="{DynamicResource Bg.Surface}">
                <Border Padding="20,12,20,20"
                        Background="{DynamicResource Bg.SurfaceElevated}"
                        CornerRadius="{DynamicResource Radius.Medium}">
                    <StackPanel Spacing="16">

                        <!-- 顶部标题行：图标 + 标题/副标题 + 已保存徽章 -->
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0"
                                    Width="32" Height="32"
                                    CornerRadius="{DynamicResource Radius.Medium}"
                                    Background="{DynamicResource Bg.SurfaceElevated}"
                                    VerticalAlignment="Center">
                                <PathIcon Data="{StaticResource Icon.Globe}"
                                          Width="16" Height="16"
                                          Foreground="{DynamicResource Accent.Stellar}"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="公网代理设置"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource Text.Primary}"/>
                                <TextBlock Text="Public Tunnel · 通过 VPS 中转访问本机"
                                           FontSize="12"
                                           Foreground="{DynamicResource Text.Secondary}"/>
                            </StackPanel>
                            <Border Grid.Column="2"
                                    Background="{DynamicResource Bg.SurfaceElevated}"
                                    CornerRadius="{DynamicResource Radius.Pill}"
                                    Padding="6,3"
                                    VerticalAlignment="Center"
                                    IsVisible="{Binding PublicRelayViewModel.Step1Done}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="6" Height="6"
                                             VerticalAlignment="Center"
                                             Fill="{DynamicResource State.Success}"/>
                                    <TextBlock Text="已保存 ✓"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource State.Success}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <TextBlock Text="通过 SSH 在 VPS 上部署代理，手机扫码通过公网中转到本机 StartTooler。"
                                   FontSize="12"
                                   Foreground="{DynamicResource Text.Secondary}"
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="⚠ 请先在「设置」里选择项目目录"
                                   FontSize="12"
                                   Foreground="{DynamicResource State.Danger}"
                                   IsVisible="{Binding PublicRelayViewModel.IsProjectPathSet, Converter={x:Static BoolConverters.Not}}"/>

                        <!--
                          两栏表单：
                          - Step1Done == false：仅显示左栏（第一步）。
                          - Step1Done == true：左栏 + 右栏并排。
                          这里用两个容器切换，避免 Grid 动态列宽问题。
                        -->

                        <!-- 未保存时：单栏第一步 -->
                        <Border Background="{DynamicResource Bg.Surface}"
                                CornerRadius="{DynamicResource Radius.Large}"
                                Padding="16"
                                IsVisible="{Binding PublicRelayViewModel.Step1Done, Converter={x:Static BoolConverters.Not}}">
                            <StackPanel Spacing="12">
                                <!-- 步骤标题 -->
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Width="20" Height="20"
                                            CornerRadius="{DynamicResource Radius.Pill}"
                                            Background="{DynamicResource Accent.Stellar}"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="1"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Text.Inverse}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="第一步：VPS 连接"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Text.Primary}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Spacing="10">
                                    <!-- 认证方式 -->
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="认证方式" FontSize="13" Foreground="{DynamicResource Text.Primary}"/>
                                        <ComboBox SelectedIndex="{Binding PublicRelayViewModel.AuthMethodIndex}"
                                                  Width="200"
                                                  HorizontalAlignment="Left">
                                            <ComboBoxItem Content="密码"/>
                                            <ComboBoxItem Content="SSH Key"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- SSH Host -->
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="SSH Host" FontSize="13" Foreground="{DynamicResource Text.Primary}"/>
                                        <TextBox Text="{Binding PublicRelayViewModel.SshHost}" Watermark="例如 47.111.138.46"/>
                                    </StackPanel>

                                    <!-- SSH Port -->
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="SSH Port" FontSize="13" Foreground="{DynamicResource Text.Primary}"/>
                                        <NumericUpDown Value="{Binding PublicRelayViewModel.SshPort}"
                                                       Minimum="1" Maximum="65535" Width="120" HorizontalAlignment="Left"/>
                                    </StackPanel>

                                    <!-- User -->
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="User" FontSize="13" Foreground="{DynamicResource Text.Primary}"/>
                                        <TextBox Text="{Binding PublicRelayViewModel.SshUser}" Watermark="SSH 用户名"/>
                                    </StackPanel>

                                    <!-- 凭据 -->
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="凭据" FontSize="13" Foreground="{DynamicResource Text.Primary}"/>
                                        <Border IsVisible="{Binding PublicRelayViewModel.ShowPasswordFields}">
                                            <TextBox Text="{Binding PublicRelayViewModel.SshPassword}"
                                                     PasswordChar="•"
                                                     Watermark="SSH 密码"/>
                                        </Border>
                                        <Border IsVisible="{Binding PublicRelayViewModel.ShowKeyFields}">
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right"
                                                        Content="浏览..."
                                                        Command="{Binding PublicRelayViewModel.BrowseKeyCommand}"
                                                        Margin="8,0,0,0"
                                                        Classes="secondary-button"/>
                                                <TextBox Text="{Binding PublicRelayViewModel.SshKeyPath}"
                                                         Watermark="例如 ~/.ssh/id_rsa"/>
                                            </DockPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- Remote Path -->
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Remote Path" FontSize="13" Foreground="{DynamicResource Text.Primary}"/>
                                        <TextBox Text="{Binding PublicRelayViewModel.SshRemotePath}" Watermark="~/starttooler"/>
                                    </StackPanel>

                                    <!-- 架构 -->
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="VPS 架构" FontSize="13" Foreground="{DynamicResource Text.Primary}"/>
                                        <ComboBox SelectedIndex="{Binding PublicRelayViewModel.RemoteArchIndex}"
                                                  Width="200"
                                                  HorizontalAlignment="Left">
                                            <ComboBoxItem Content="自动检测"/>
                                            <ComboBoxItem Content="amd64"/>
                                            <ComboBoxItem Content="arm64"/>
                                        </ComboBox>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Button Content="保存 VPS 连接"
                                            Classes="primary-button"
                                            Command="{Binding PublicRelayViewModel.SaveCommand}"
                                            IsEnabled="{Binding PublicRelayViewModel.IsDirty}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- 已保存时：左右两栏 -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="16"
                              IsVisible="{Binding PublicRelayViewModel.Step1Done}">
                            <!-- 左栏：第一步 VPS 连接 -->
                            <Border Grid.Column="0"
                                    Background="{DynamicResource Bg.Surface}"
                                    CornerRadius="{DynamicResource Radius.Large}"
                                    Padding="16">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border Width="20" Height="20"
                                                CornerRadius="{DynamicResource Radius.Pill}"
                                                Background="{DynamicResource State.Success}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="✓"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Text.Inverse}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="第一步：VPS 连接"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Text.Primary}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Spacing="10">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="认证方式" FontSize="13" Foreground="{DynamicResource Text.Primary}"/>
                                            <ComboBox SelectedIndex="{Binding PublicRelayViewModel.AuthMethodIndex}"
                                                      Width="200"
                                                      HorizontalAlignment="Left">
                                                <ComboBoxItem Content="密码"/>
                                                <ComboBoxItem Content="SSH Key"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="SSH Host" FontSize="13" Foreground="{DynamicResource Text.Primary}"/>
                                            <TextBox Text="{Binding PublicRelayViewModel.SshHost}" Watermark="例如 47.111.138.46"/>
                                        </StackPanel>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="SSH Port" FontSize="13" Foreground="{DynamicResource Text.Primary}"/>
                                            <NumericUpDown Value="{Binding PublicRelayViewModel.SshPort}"
                                                           Minimum="1" Maximum="65535" Width="120" HorizontalAlignment="Left"/>
                                        </StackPanel>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="User" FontSize="13" Foreground="{DynamicResource Text.Primary}"/>
                                            <TextBox Text="{Binding PublicRelayViewModel.SshUser}" Watermark="SSH 用户名"/>
                                        </StackPanel>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="凭据" FontSize="13" Foreground="{DynamicResource Text.Primary}"/>
                                            <Border IsVisible="{Binding PublicRelayViewModel.ShowPasswordFields}">
                                                <TextBox Text="{Binding PublicRelayViewModel.SshPassword}"
                                                         PasswordChar="•"
                                                         Watermark="SSH 密码"/>
                                            </Border>
                                            <Border IsVisible="{Binding PublicRelayViewModel.ShowKeyFields}">
                                                <DockPanel>
                                                    <Button DockPanel.Dock="Right"
                                                            Content="浏览..."
                                                            Command="{Binding PublicRelayViewModel.BrowseKeyCommand}"
                                                            Margin="8,0,0,0"
                                                            Classes="secondary-button"/>
                                                    <TextBox Text="{Binding PublicRelayViewModel.SshKeyPath}"
                                                             Watermark="例如 ~/.ssh/id_rsa"/>
                                                </DockPanel>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Remote Path" FontSize="13" Foreground="{DynamicResource Text.Primary}"/>
                                            <TextBox Text="{Binding PublicRelayViewModel.SshRemotePath}" Watermark="~/starttooler"/>
                                        </StackPanel>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="VPS 架构" FontSize="13" Foreground="{DynamicResource Text.Primary}"/>
                                            <ComboBox SelectedIndex="{Binding PublicRelayViewModel.RemoteArchIndex}"
                                                      Width="200"
                                                      HorizontalAlignment="Left">
                                                <ComboBoxItem Content="自动检测"/>
                                                <ComboBoxItem Content="amd64"/>
                                                <ComboBoxItem Content="arm64"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Button Content="保存"
                                                Classes="primary-button"
                                                Command="{Binding PublicRelayViewModel.SaveCommand}"
                                                IsEnabled="{Binding PublicRelayViewModel.IsDirty}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- 右栏：第二步服务配置 -->
                            <Border Grid.Column="1"
                                    Background="{DynamicResource Bg.Surface}"
                                    CornerRadius="{DynamicResource Radius.Large}"
                                    Padding="16">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border Width="20" Height="20"
                                                CornerRadius="{DynamicResource Radius.Pill}"
                                                Background="{DynamicResource Accent.Stellar}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="2"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Text.Inverse}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="第二步：服务配置"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Text.Primary}"
                                                   VerticalAlignment="Center"/>
                                        <Border Background="{DynamicResource Bg.SurfaceElevated}"
                                                CornerRadius="{DynamicResource Radius.Pill}"
                                                Padding="6,3"
                                                VerticalAlignment="Center"
                                                IsVisible="{Binding PublicRelayViewModel.Step2Done}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Ellipse Width="6" Height="6"
                                                         VerticalAlignment="Center"
                                                         Fill="{DynamicResource State.Success}"/>
                                                <TextBlock Text="已部署 ✓"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource State.Success}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Spacing="10">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="HTTP Port" FontSize="13" Foreground="{DynamicResource Text.Primary}"/>
                                            <NumericUpDown Value="{Binding PublicRelayViewModel.HttpPort}"
                                                           Minimum="1" Maximum="65535" Width="120" HorizontalAlignment="Left"/>
                                        </StackPanel>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="TCP Port" FontSize="13" Foreground="{DynamicResource Text.Primary}"/>
                                            <NumericUpDown Value="{Binding PublicRelayViewModel.TcpPort}"
                                                           Minimum="1" Maximum="65535" Width="120" HorizontalAlignment="Left"/>
                                        </StackPanel>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="公网 Host" FontSize="13" Foreground="{DynamicResource Text.Primary}"/>
                                            <TextBox Text="{Binding PublicRelayViewModel.PublicHost}" Watermark="留空用 SSH Host"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                            <Button Content="部署"
                                                    Classes="secondary-button"
                                                    Command="{Binding PublicRelayViewModel.DeployCommand}"
                                                    IsEnabled="{Binding PublicRelayViewModel.CanDeploy}"/>
                                            <Button Content="启动"
                                                    Classes="primary-button"
                                                    Command="{Binding PublicRelayViewModel.StartCommand}"
                                                    IsEnabled="{Binding PublicRelayViewModel.CanStart}"/>
                                            <Button Content="停止"
                                                    Classes="secondary-button"
                                                    Command="{Binding PublicRelayViewModel.StopCommand}"
                                                    IsVisible="{Binding PublicRelayViewModel.IsPublicRelayRunning}"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                            <TextBlock Text="状态" FontSize="13" Foreground="{DynamicResource Text.Primary}" VerticalAlignment="Center"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <Ellipse Width="10" Height="10" Fill="{Binding PublicRelayViewModel.RelayStateColor}"/>
                                                <TextBlock Text="{Binding PublicRelayViewModel.RelayStateText}"
                                                           FontSize="13"
                                                           Foreground="{DynamicResource Text.Primary}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="待下载" FontSize="13" Foreground="{DynamicResource Text.Primary}" VerticalAlignment="Center"/>
                                            <TextBlock FontSize="13" Foreground="{DynamicResource Text.Secondary}" VerticalAlignment="Center">
                                                <Run Text="{Binding PublicRelayViewModel.PendingCount}"/>
                                                <Run Text=" 个"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <StackPanel Spacing="4"
                                                    IsVisible="{Binding PublicRelayViewModel.LastError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <TextBlock Text="错误" FontSize="13" Foreground="{DynamicResource Text.Primary}"/>
                                            <TextBlock Text="{Binding PublicRelayViewModel.LastError}"
                                                       FontSize="12" Foreground="{DynamicResource State.Danger}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Border Background="{DynamicResource Bg.SurfaceElevated}"
                                            CornerRadius="{DynamicResource Radius.Medium}"
                                            Padding="12">
                                        <StackPanel Spacing="8">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Grid.Column="0"
                                                           Text="运行日志"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Text.Primary}"
                                                           VerticalAlignment="Center"/>
                                                <Button Grid.Column="1"
                                                        Content="清空日志"
                                                        Classes="secondary-button"
                                                        Command="{Binding PublicRelayViewModel.ClearLogCommand}"
                                                        Padding="10,4"
                                                        FontSize="11"/>
                                            </Grid>
                                            <TextBox Text="{Binding PublicRelayViewModel.LogText}"
                                                     IsReadOnly="True"
                                                     TextWrapping="Wrap"
                                                     AcceptsReturn="True"
                                                     MinHeight="80"
                                                     MaxHeight="200"
                                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                     FontFamily="{DynamicResource Font.Mono}"
                                                     FontSize="11"
                                                     Foreground="{DynamicResource Text.Secondary}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</UserControl>
