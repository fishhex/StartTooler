<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StartTooler.ViewModels"
             x:Class="StartTooler.Views.UploadServerView"
             x:DataType="vm:UploadServerViewModel">

    <ScrollViewer>
        <StackPanel Margin="40,24" Spacing="24">

            <!-- 标题 -->
            <TextBlock Text="上传服务"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource Text.Primary}"/>

            <!-- 服务控制 + 二维码（合并 card，运行时二维码在右侧） -->
            <Border Background="{DynamicResource Bg.Surface}"
                    CornerRadius="8"
                    Padding="24">
                <Grid ColumnDefinitions="*,Auto">
                    <!-- 左：服务控制 -->
                    <StackPanel Grid.Column="0" Spacing="16">
                        <TextBlock Text="局域网上传"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Text.Primary}"/>

                        <TextBlock Text="在其他设备上打开以下链接，上传图片或视频。文件会自动按日期归档到当前项目目录。"
                                   FontSize="12"
                                   Foreground="{DynamicResource Text.Secondary}"
                                   TextWrapping="Wrap"/>

                        <!-- 端口配置 + 随机端口按钮（冲突时显示） -->
                        <Grid ColumnDefinitions="100,*">
                            <TextBlock Grid.Column="0"
                                       Text="端口"
                                       FontSize="13"
                                       Foreground="{DynamicResource Text.Primary}"
                                       VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                                <NumericUpDown Value="{Binding Port}"
                                               Minimum="1024"
                                               Maximum="65535"
                                               Width="120"
                                               IsEnabled="{Binding !IsRunning}"
                                               VerticalAlignment="Center"/>
                                <!-- v0.11: 🎲 随机端口 → 纯文字 "随机端口"（spec §13.1） -->
                                <Button Content="随机端口"
                                        Command="{Binding UseRandomPortCommand}"
                                        IsVisible="{Binding IsPortConflict}"
                                        VerticalAlignment="Center"
                                        Classes="secondary-button"/>
                            </StackPanel>
                        </Grid>

                        <!-- 端口冲突时的建议端口 -->
                        <StackPanel Spacing="6"
                                    IsVisible="{Binding IsPortConflict}">
                            <TextBlock Text="建议端口："
                                       FontSize="12"
                                       Foreground="{DynamicResource Text.Secondary}"/>
                            <ItemsControl ItemsSource="{Binding SuggestedPorts}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding}"
                                                Command="{Binding $parent[UserControl].DataContext.UseRandomPortCommand}"
                                                CommandParameter="{Binding}"
                                                Margin="0,0,6,0"
                                                Padding="10,4"
                                                Classes="secondary-button"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- 启动按钮 -->
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button Content="启动服务"
                                    Classes="primary-button"
                                    Command="{Binding StartServerCommand}"
                                    IsVisible="{Binding !IsRunning}"/>
                            <Button Content="停止服务"
                                    Classes="secondary-button"
                                    Command="{Binding StopServerCommand}"
                                    IsVisible="{Binding IsRunning}"/>
                        </StackPanel>

                        <!-- 状态消息（端口冲突时 State.Danger 颜色，否则 State.Success） -->
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="12"
                                   Foreground="{DynamicResource State.Danger}"
                                   IsVisible="{Binding IsPortConflict}"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="12"
                                   Foreground="{DynamicResource State.Success}"
                                   IsVisible="{Binding ShowSuccessStatus}"/>

                        <!-- 错误消息 -->
                        <TextBlock Text="{Binding ErrorMessage}"
                                   FontSize="12"
                                   Foreground="{DynamicResource State.Danger}"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                        <!-- 上传历史（最多 50 条 ScrollViewer 滚动；空时不显示） -->
                        <StackPanel Spacing="6"
                                    IsVisible="{Binding HasUploadHistory}">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="最近上传"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource Text.Primary}"
                                           VerticalAlignment="Center"/>
                                <!-- v0.11: 「清除」按钮（spec §13.2） -->
                                <Button Grid.Column="1"
                                        Content="清除"
                                        Classes="toolbar-button"
                                        FontSize="11"
                                        Command="{Binding ClearUploadHistoryCommand}"/>
                            </Grid>
                            <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding UploadHistory}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                                                <TextBlock Text="{Binding FileName}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource Text.Primary}"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="220"/>
                                                <TextBlock Text="{Binding FileSize, StringFormat={}{0:N0} B}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource Text.Secondary}"/>
                                                <TextBlock Text="✓"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource State.Success}"
                                                           IsVisible="{Binding IsSuccess}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </StackPanel>

                    <!-- 右：二维码（运行时显示） -->
                    <StackPanel Grid.Column="1"
                                Spacing="12"
                                Margin="24,0,0,0"
                                VerticalAlignment="Top"
                                IsVisible="{Binding IsRunning}">
                        <TextBlock Text="扫码上传"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Text.Primary}"
                                   HorizontalAlignment="Center"/>

                        <Border Background="{DynamicResource Accent.Stellar}"
                                CornerRadius="3"
                                Padding="6,2"
                                HorizontalAlignment="Center"
                                IsVisible="{Binding IsPublicMode}">
                            <TextBlock Text="公网中转中"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="White"/>
                        </Border>

                        <Image Source="{Binding QrCodeImage}"
                               Width="180"
                               Height="180"
                               HorizontalAlignment="Center"/>

                        <!-- URL：可读 TextBox + 复制按钮（spec §3.2） -->
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0"
                                     Text="{Binding UploadUrl}"
                                     IsReadOnly="True"
                                     FontSize="11"
                                     MinWidth="260"
                                     VerticalAlignment="Center"
                                     ToolTip.Tip="{Binding UploadUrl}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled"/>
                            <!--
                              v0.11: 复制按钮默认显示 Icon.Copy，点击后 1.5s 显示 "已复制"（spec §13.1）。
                              XAML 端用 Grid 叠加：默认显示图标，点击后 CopyButtonText="已复制" 时显示文字。
                              Button 设 MinWidth 避免文字切换时挤压 TextBox。
                            -->
                            <Button Grid.Column="1"
                                    Command="{Binding CopyUrlCommand}"
                                    Classes="secondary-button"
                                    Margin="4,0,0,0"
                                    Padding="8,4"
                                    MinWidth="64"
                                    VerticalAlignment="Center"
                                    ToolTip.Tip="复制 URL">
                                <Panel>
                                    <PathIcon Data="{StaticResource Icon.Copy}"
                                              Width="12" Height="12"
                                              Foreground="{DynamicResource Text.Secondary}"
                                              IsVisible="{Binding CopyButtonText, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                                    <TextBlock Text="{Binding CopyButtonText}"
                                               FontSize="11"
                                               Foreground="{DynamicResource Text.Secondary}"
                                               IsVisible="{Binding CopyButtonText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                </Panel>
                            </Button>
                        </Grid>

                        <!-- 多 IP 列表（spec §3.4） -->
                        <StackPanel Spacing="4"
                                    IsVisible="{Binding HasLocalAddresses}">
                            <TextBlock Text="本机 IP："
                                       FontSize="11"
                                       Foreground="{DynamicResource Text.Secondary}"
                                       HorizontalAlignment="Center"/>
                            <ItemsControl ItemsSource="{Binding LocalAddresses}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource Text.Primary}"/>
                                            <!-- v0.11: 📋 emoji → Icon.Copy 图标（spec §13.1） -->
                                            <Button Padding="6,2"
                                                    Command="{Binding $parent[UserControl].DataContext.CopyAddressCommand}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip.Tip="复制 IP">
                                                <PathIcon Data="{StaticResource Icon.Copy}"
                                                          Width="11" Height="11"
                                                          Foreground="{DynamicResource Text.Secondary}"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- 最近一次上传的瞬时提示（保留 v0.10 行为；详细列表走 ScrollViewer） -->
                        <TextBlock Text="{Binding RecentUploadMessage}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Accent.Stellar}"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="220"
                                   IsVisible="{Binding RecentUploadMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 公网代理设置（折叠在下方，默认折叠） -->
            <Expander Header="公网代理设置"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
                <Border Padding="20,12,20,20"
                        Background="{DynamicResource Bg.SurfaceElevated}"
                        CornerRadius="6">
                    <StackPanel Spacing="12">

                        <TextBlock Text="通过 SSH 在 VPS 上部署代理，手机扫码通过公网中转到本机 StartTooler。"
                                   FontSize="12"
                                   Foreground="{DynamicResource Text.Secondary}"
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="⚠ 请先在「设置」里选择项目目录"
                                   FontSize="12"
                                   Foreground="{DynamicResource State.Danger}"
                                   IsVisible="{Binding PublicRelayViewModel.IsProjectPathSet, Converter={x:Static BoolConverters.Not}}"/>

                        <!-- 第一步：VPS 连接（spec §4.1） -->
                        <Border Background="{DynamicResource Bg.Surface}"
                                CornerRadius="8"
                                Padding="16">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="第一步：VPS 连接"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Text.Primary}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="已保存 ✓"
                                               FontSize="12"
                                               Foreground="{DynamicResource State.Success}"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding PublicRelayViewModel.Step1Done}"/>
                                </Grid>

                                <!-- 认证方式 -->
                                <Grid ColumnDefinitions="100,*">
                                    <TextBlock Grid.Column="0" Text="认证方式" FontSize="13" Foreground="{DynamicResource Text.Primary}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1"
                                              SelectedIndex="{Binding PublicRelayViewModel.AuthMethodIndex}"
                                              Width="200"
                                              HorizontalAlignment="Left">
                                        <ComboBoxItem Content="密码"/>
                                        <ComboBoxItem Content="SSH Key"/>
                                    </ComboBox>
                                </Grid>

                                <!-- SSH Host -->
                                <Grid ColumnDefinitions="100,*">
                                    <TextBlock Grid.Column="0" Text="SSH Host" FontSize="13" Foreground="{DynamicResource Text.Primary}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding PublicRelayViewModel.SshHost}" Watermark="例如 vps.example.com"/>
                                </Grid>

                                <!-- SSH Port -->
                                <Grid ColumnDefinitions="100,*">
                                    <TextBlock Grid.Column="0" Text="SSH Port" FontSize="13" Foreground="{DynamicResource Text.Primary}" VerticalAlignment="Center"/>
                                    <NumericUpDown Grid.Column="1" Value="{Binding PublicRelayViewModel.SshPort}"
                                                   Minimum="1" Maximum="65535" Width="120" HorizontalAlignment="Left"/>
                                </Grid>

                                <!-- User -->
                                <Grid ColumnDefinitions="100,*">
                                    <TextBlock Grid.Column="0" Text="User" FontSize="13" Foreground="{DynamicResource Text.Primary}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding PublicRelayViewModel.SshUser}" Watermark="SSH 用户名"/>
                                </Grid>

                                <!-- 认证切换防抖：Password / Key 区域 MinHeight 固定（spec §4.2） -->
                                <Grid ColumnDefinitions="100,*">
                                    <TextBlock Grid.Column="0" Text="凭据" FontSize="13" Foreground="{DynamicResource Text.Primary}" VerticalAlignment="Top" Margin="0,8,0,0"/>
                                    <StackPanel Grid.Column="1" Spacing="6">
                                        <Border MinHeight="60"
                                                IsVisible="{Binding PublicRelayViewModel.ShowPasswordFields}">
                                            <TextBox Text="{Binding PublicRelayViewModel.SshPassword}"
                                                     PasswordChar="•"
                                                     Watermark="SSH 密码"
                                                     VerticalAlignment="Top"/>
                                        </Border>
                                        <Border MinHeight="60"
                                                IsVisible="{Binding PublicRelayViewModel.ShowKeyFields}">
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right"
                                                        Content="浏览..."
                                                        Command="{Binding PublicRelayViewModel.BrowseKeyCommand}"
                                                        Margin="8,0,0,0"
                                                        Classes="secondary-button"/>
                                                <TextBox Text="{Binding PublicRelayViewModel.SshKeyPath}"
                                                         Watermark="例如 ~/.ssh/id_rsa"
                                                         VerticalAlignment="Top"/>
                                            </DockPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <!-- Remote Path -->
                                <Grid ColumnDefinitions="100,*">
                                    <TextBlock Grid.Column="0" Text="Remote Path" FontSize="13" Foreground="{DynamicResource Text.Primary}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding PublicRelayViewModel.SshRemotePath}" Watermark="~/starttooler"/>
                                </Grid>

                                <!-- 架构 -->
                                <Grid ColumnDefinitions="100,*">
                                    <TextBlock Grid.Column="0" Text="VPS 架构" FontSize="13" Foreground="{DynamicResource Text.Primary}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1"
                                              SelectedIndex="{Binding PublicRelayViewModel.RemoteArchIndex}"
                                              Width="200"
                                              HorizontalAlignment="Left">
                                        <ComboBoxItem Content="自动检测"/>
                                        <ComboBoxItem Content="amd64"/>
                                        <ComboBoxItem Content="arm64"/>
                                    </ComboBox>
                                </Grid>

                                <!-- 第一步底部：保存 -->
                                <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,0">
                                    <Button Content="保存"
                                            Classes="primary-button"
                                            Command="{Binding PublicRelayViewModel.SaveCommand}"
                                            IsEnabled="{Binding PublicRelayViewModel.IsDirty}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- 第二步：服务配置（Step1Done 后才显示） -->
                        <Border Background="{DynamicResource Bg.Surface}"
                                CornerRadius="8"
                                Padding="16"
                                IsVisible="{Binding PublicRelayViewModel.Step1Done}">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="第二步：服务配置"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Text.Primary}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="已部署 ✓"
                                               FontSize="12"
                                               Foreground="{DynamicResource State.Success}"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding PublicRelayViewModel.Step2Done}"/>
                                </Grid>

                                <!-- HTTP Port -->
                                <Grid ColumnDefinitions="100,*">
                                    <TextBlock Grid.Column="0" Text="HTTP Port" FontSize="13" Foreground="{DynamicResource Text.Primary}" VerticalAlignment="Center"/>
                                    <NumericUpDown Grid.Column="1" Value="{Binding PublicRelayViewModel.HttpPort}"
                                                   Minimum="1" Maximum="65535" Width="120" HorizontalAlignment="Left"/>
                                </Grid>

                                <!-- TCP Port -->
                                <Grid ColumnDefinitions="100,*">
                                    <TextBlock Grid.Column="0" Text="TCP Port" FontSize="13" Foreground="{DynamicResource Text.Primary}" VerticalAlignment="Center"/>
                                    <NumericUpDown Grid.Column="1" Value="{Binding PublicRelayViewModel.TcpPort}"
                                                   Minimum="1" Maximum="65535" Width="120" HorizontalAlignment="Left"/>
                                </Grid>

                                <!-- Public Host -->
                                <Grid ColumnDefinitions="100,*">
                                    <TextBlock Grid.Column="0" Text="公网 Host" FontSize="13" Foreground="{DynamicResource Text.Primary}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding PublicRelayViewModel.PublicHost}" Watermark="留空用 SSH Host"/>
                                </Grid>

                                <!-- 线性按钮组（spec §4.1） -->
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                                    <Button Content="部署"
                                            Classes="secondary-button"
                                            Command="{Binding PublicRelayViewModel.DeployCommand}"
                                            IsEnabled="{Binding PublicRelayViewModel.CanDeploy}"/>
                                    <Button Content="启动"
                                            Classes="primary-button"
                                            Command="{Binding PublicRelayViewModel.StartCommand}"
                                            IsEnabled="{Binding PublicRelayViewModel.CanStart}"/>
                                    <Button Content="停止"
                                            Classes="secondary-button"
                                            Command="{Binding PublicRelayViewModel.StopCommand}"
                                            IsVisible="{Binding PublicRelayViewModel.IsPublicRelayRunning}"/>
                                </StackPanel>

                                <!-- 彩色状态指示器（spec §4.4） + 待下载 -->
                                <Grid ColumnDefinitions="100,*" Margin="0,8,0,0">
                                    <TextBlock Grid.Column="0" Text="状态" FontSize="13" Foreground="{DynamicResource Text.Primary}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Ellipse Width="10" Height="10" Fill="{Binding PublicRelayViewModel.RelayStateColor}"/>
                                        <TextBlock Text="{Binding PublicRelayViewModel.RelayStateText}"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource Text.Primary}"/>
                                    </StackPanel>
                                </Grid>

                                <Grid ColumnDefinitions="100,*">
                                    <TextBlock Grid.Column="0" Text="待下载" FontSize="13" Foreground="{DynamicResource Text.Primary}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               FontSize="13" Foreground="{DynamicResource Text.Secondary}" VerticalAlignment="Center">
                                        <Run Text="{Binding PublicRelayViewModel.PendingCount}"/>
                                        <Run Text=" 个"/>
                                    </TextBlock>
                                </Grid>

                                <!-- 错误 -->
                                <Grid ColumnDefinitions="100,*"
                                      IsVisible="{Binding PublicRelayViewModel.LastError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <TextBlock Grid.Column="0" Text="错误" FontSize="13" Foreground="{DynamicResource Text.Primary}" VerticalAlignment="Top" Margin="0,6,0,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding PublicRelayViewModel.LastError}"
                                               FontSize="12" Foreground="{DynamicResource State.Danger}"
                                               TextWrapping="Wrap" VerticalAlignment="Top" Margin="0,6,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 多行日志（spec §4.3） -->
                        <Border Background="{DynamicResource Bg.Surface}"
                                CornerRadius="8"
                                Padding="16"
                                IsVisible="{Binding PublicRelayViewModel.Step1Done}">
                            <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="运行日志"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Text.Primary}"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1"
                                            Content="清空日志"
                                            Classes="secondary-button"
                                            Command="{Binding PublicRelayViewModel.ClearLogCommand}"
                                            Padding="10,4"
                                            FontSize="11"/>
                                </Grid>
                                <TextBox Text="{Binding PublicRelayViewModel.LogText}"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         MinHeight="80"
                                         MaxHeight="200"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         FontFamily="Cascadia Code,Consolas,monospace"
                                         FontSize="11"
                                         Foreground="{DynamicResource Text.Secondary}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</UserControl>
