<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:StartTooler.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="400"
        x:Class="StartTooler.Views.SettingsWindow"
        x:Name="Root"
        x:DataType="vm:SettingsViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="设置">

    <Design.DataContext>
        <vm:SettingsViewModel/>
    </Design.DataContext>

    <Window.DataTemplates>
        <DataTemplate DataType="{x:Type vm:AiSettingsViewModel}">
            <Grid RowDefinitions="Auto,Auto,Auto">
                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="API 地址" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding ApiUrl}" 
                             Watermark="例如：https://api.openai.com/v1"
                             Padding="8"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Margin="0,0,0,15">
                    <TextBlock Text="API Token" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding ApiToken}" 
                             Watermark="输入你的 API Token"
                             PasswordChar="*"
                             Padding="8"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Margin="0,0,0,15">
                    <TextBlock Text="模型名称" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding ModelName}" 
                             Watermark="例如：gpt-4"
                             Padding="8"/>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </Window.DataTemplates>

    <Grid ColumnDefinitions="180,*" Margin="0">
        <!-- 左侧导航 -->
        <Border Grid.Column="0" Background="#F5F5F5" Padding="10">
            <ListBox ItemsSource="{Binding Pages}"
                     SelectedItem="{Binding SelectedPage}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Title}"
                                   FontSize="13"
                                   Padding="5,8"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- 右侧内容 -->
        <Grid Grid.Column="1" RowDefinitions="*,Auto" Margin="20">
            <ScrollViewer Grid.Row="0">
                <ContentControl Content="{Binding SelectedPage.Content}"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Stretch"/>
            </ScrollViewer>

            <StackPanel Grid.Row="1" Orientation="Horizontal"
                        HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
                <Button Content="保存" 
                        Command="{Binding SaveCommand}"
                        Padding="20,8"
                        IsDefault="True"/>
                <Button Content="取消" 
                        Click="OnCancelButton_Click"
                        Padding="20,8"
                        IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Grid>

</Window>
