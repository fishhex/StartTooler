<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:StartTooler.ViewModels"
             mc:Ignorable="d"
             x:Class="StartTooler.Controls.NavRail"
             x:DataType="vm:MainWindowViewModel">

    <Border Padding="0,86,0,32">
        <Grid RowDefinitions="Auto,*">
            <StackPanel Grid.Row="0" Spacing="8">
            <!-- 媒体按钮 (C15 NavItem) -->
            <Button x:Name="MediaButton"
                    Classes="nav-item"
                    Command="{Binding NavigateToMediaCommand}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="4">
                    <Path Data="{DynamicResource Icon.Photo}"
                          Width="16" Height="16"
                          Stretch="Uniform"/>
                    <TextBlock Text="媒体"
                               FontSize="11"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
            </StackPanel>

            <!-- 设置按钮 (C15 NavItem) -->
            <Button Grid.Row="1"
                    x:Name="SettingsButton"
                    Classes="nav-item"
                    Command="{Binding NavigateToSettingsCommand}"
                    VerticalAlignment="Bottom"
                    Margin="0,16,0,0">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="4">
                    <Path Data="{DynamicResource Icon.Settings}"
                          Width="16" Height="16"
                          Stretch="Uniform"/>
                    <TextBlock Text="设置"
                               FontSize="11"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
    </Border>
</UserControl>
