<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:StartTooler.ViewModels"
             mc:Ignorable="d"
             x:Class="StartTooler.Controls.NavRail"
             x:DataType="vm:MainWindowViewModel">

    <Grid RowDefinitions="Auto,Auto,Auto,*">
        <!-- 媒体按钮 (C15 NavItem) -->
        <Button Grid.Row="0"
                x:Name="MediaButton"
                Height="48"
                Classes="nav-item"
                Classes.active="{Binding IsMediaActive}"
                Command="{Binding NavigateToMediaCommand}"
                VerticalAlignment="Center"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Padding="0">
            <TextBlock Text="媒体"
                       FontSize="11"
                       LineHeight="14"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Button>

        <!-- 上传服务按钮（紧贴媒体） -->
        <Button Grid.Row="1"
                x:Name="UploadServerButton"
                Height="48"
                Classes="nav-item"
                Classes.active="{Binding IsUploadServerActive}"
                Command="{Binding NavigateToUploadServerCommand}"
                VerticalAlignment="Center"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Padding="0">
            <TextBlock Text="上传"
                       FontSize="11"
                       LineHeight="14"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Button>

        <!-- v0.8: 垃圾筒按钮（紧贴上传，spec §9.2） -->
        <Button Grid.Row="2"
                x:Name="TrashButton"
                Height="48"
                Classes="nav-item"
                Classes.active="{Binding IsTrashActive}"
                Command="{Binding NavigateToTrashCommand}"
                VerticalAlignment="Center"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Padding="0">
            <TextBlock Text="垃圾筒"
                       FontSize="11"
                       LineHeight="14"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Button>

        <!-- 设置按钮 (C15 NavItem) -->
        <Button Grid.Row="3"
                x:Name="SettingsButton"
                Height="48"
                Classes="nav-item"
                Classes.active="{Binding IsSettingsActive}"
                Command="{Binding NavigateToSettingsCommand}"
                VerticalAlignment="Bottom"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Padding="0">
            <TextBlock Text="设置"
                       FontSize="11"
                       LineHeight="14"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Button>
    </Grid>
</UserControl>
